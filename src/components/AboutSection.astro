---
import { heroStats } from '../data/site';
---
<section class="section bg-white">
  <div class="container">
    <div class="ab-grid">

      <div class="ab-copy reveal">
        <span class="section-tag">Who We Are</span>
        <h2>Nigeria's Most <span class="text-gradient">Trusted</span> Solar Company</h2>
        <p>
          Founded in 2008, TECIL Solar is the renewable energy division of Tecil Integrated Services Limited — operating across Lagos, Port Harcourt, Calabar, Uyo, Ikom and beyond for over 16 years.
        </p>
        <p style="margin-top:.9rem">
          We deliver <strong>end-to-end solar solutions</strong> — from a single home installation to a 60KW off-grid industrial system. Our edge isn't the cheapest price. It's technical depth, honest advice, and systems that outlast their warranties.
        </p>
        <div class="ab-values">
          {['Excellence','Innovation','Integrity','Sustainability'].map(v=><span class="av">{v}</span>)}
        </div>
        <div class="ab-btns">
          <a href="/projects" class="btn-primary">Our Track Record</a>
          <a href="/services" class="btn-outline">Our Services</a>
        </div>
      </div>

      <div class="ab-right">
        <div class="ab-stats">
          {heroStats.map((s,i)=>(
            <div class={`ab-stat reveal reveal-delay-${i+1}`}>
              <strong>{s.value}</strong>
              <span>{s.label}</span>
            </div>
          ))}
        </div>
        <div class="ab-mission reveal reveal-delay-2">
          <div class="abm-bar"></div>
          <p>"To build a reputation as the leading, most knowledgeable, most reliable and most customer-friendly renewable energy company in Africa."</p>
          <cite>TECIL Solar — Mission Statement</cite>
        </div>
      </div>

    </div>
  </div>
</section>
<style>
.ab-grid { display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center; }
.ab-copy h2 { color:#111827;margin-bottom:1.1rem; }
.ab-copy p { color:#4B5563; }
.ab-copy p strong { color:#111827;font-weight:600; }
.ab-values { display:flex;flex-wrap:wrap;gap:7px;margin:1.4rem 0 1.75rem; }
.av { background:#FFF5EE;border:1.5px solid rgba(232,96,26,.25);color:#E8601A;font-size:.7rem;font-weight:700;padding:5px 12px;border-radius:999px;letter-spacing:.04em;text-transform:uppercase; font-variation-settings:'wdth' 100,'wght' 700; }
.ab-btns { display:flex;gap:10px;flex-wrap:wrap; }

.ab-stats { display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-bottom:2px; }
.ab-stat { background:#F7F8FA;border:1px solid #E5E7EB;padding:1.75rem;position:relative;overflow:hidden;transition:all .3s ease; }
.ab-stat::before { content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#CC1417,#E8601A);transform:scaleX(0);transform-origin:left;transition:transform .3s ease; }
.ab-stat:hover { background:#fff;box-shadow:0 6px 20px rgba(0,0,0,.07);transform:translateY(-2px); }
.ab-stat:hover::before { transform:scaleX(1); }
.ab-stat strong { display:block;font-family:'Nunito Sans',sans-serif;font-size:2.6rem;color:#CC1417;line-height:1;margin-bottom:4px;font-variation-settings:'wdth' 125,'wght' 900; }
.ab-stat span { font-size:.72rem;font-weight:600;color:#6B7280;text-transform:uppercase;letter-spacing:.06em;font-variation-settings:'wdth' 100,'wght' 600; }

.ab-mission { background:#FFF1F1;border-left:4px solid #CC1417;padding:1.4rem 1.6rem;display:flex;flex-direction:column;gap:6px; }
.abm-bar { width:22px;height:2px;background:#CC1417; }
.ab-mission p { font-size:.9rem;color:#4B5563;font-style:italic;line-height:1.75; }
.ab-mission cite { font-size:.66rem;font-weight:700;color:#CC1417;text-transform:uppercase;letter-spacing:.1em; }

@media(max-width:900px){ .ab-grid{grid-template-columns:1fr;gap:3rem} }
</style>
