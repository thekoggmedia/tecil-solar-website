---
import { heroStats, principles } from '../data/site';
---

<section class="section bg-white about-section">
  <div class="container about-shell">
    <div class="about-copy reveal">
      <span class="section-tag">Why Tecil Solar</span>
      <h2>Built to look premium. Engineered to feel reliable.</h2>
      <p class="about-lead">
        We removed the heavy visual noise and built a brighter, cleaner layout that reflects a brand people can trust.
      </p>
      <p>
        The focus is now on clarity, balance, and strength: a strong logo presence, cleaner color flow, better contrast,
        and stronger content hierarchy.
      </p>

      <div class="about-actions">
        <a href="/services" class="btn-outline">Explore Services</a>
        <a href="/contact" class="btn-primary">Talk to Us</a>
      </div>
    </div>

    <div class="about-panel reveal reveal-delay-2">
      <div class="about-stats">
        {heroStats.map((item) => (
          <div class="about-stat">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </div>
        ))}
      </div>

      <div class="about-principles">
        {principles.map((item) => (
          <article class="principle-card">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(340px, 0.98fr);
    gap: 3rem;
    align-items: start;
  }

  .about-copy h2 {
    max-width: 11ch;
  }

  .about-lead {
    margin-top: 1rem;
    font-size: 1.08rem;
  }

  .about-copy p + p {
    margin-top: 1rem;
  }

  .about-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.7rem;
  }

  .about-panel {
    padding: 1.25rem;
    border-radius: 28px;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, #fff, var(--off));
    box-shadow: 0 16px 40px rgba(15,23,42,0.08);
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    overflow: hidden;
    border-radius: 22px;
    background: var(--border);
  }

  .about-stat {
    padding: 1.2rem;
    background: #fff;
  }

  .about-stat strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2.15rem;
    line-height: 1;
  }

  .about-stat span {
    display: block;
    margin-top: 0.4rem;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--soft);
  }

  .about-principles {
    display: grid;
    gap: 0.9rem;
    margin-top: 1rem;
  }

  .principle-card {
    padding: 1.15rem 1.15rem 1.05rem;
    border-radius: 22px;
    background: #fff;
    border: 1px solid var(--border);
  }

  .principle-card h3 {
    font-size: 1.35rem;
    margin-bottom: 0.4rem;
  }

  .principle-card p {
    font-size: 0.98rem;
  }

  @media (max-width: 980px) {
    .about-shell {
      grid-template-columns: 1fr;
    }
  }
</style>