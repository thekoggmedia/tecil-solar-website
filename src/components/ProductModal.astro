---
// ProductModal.astro
---

<div id="product-modal" class="pmodal">
  <div class="pmodal-overlay" id="pmodal-close"></div>

  <div class="pmodal-container">

    <!-- CLOSE -->
    <button class="pmodal-close" id="pmodal-close-btn">✕</button>

    <!-- CONTENT -->
    <div class="pmodal-content">

      <!-- LEFT: IMAGE -->
      <div class="pmodal-media">
        <img id="pmodal-image" src="" alt="">
      </div>

      <!-- RIGHT: DETAILS -->
      <div class="pmodal-info">

        <div class="pmodal-head">
          <div id="pmodal-brand" class="pmodal-brand"></div>
          <h2 id="pmodal-name" class="pmodal-title"></h2>
        </div>

        <div class="pmodal-specs" id="pmodal-specs"></div>

        <div class="pmodal-price-wrap">
          <div id="pmodal-price" class="pmodal-price"></div>
          <span class="pmodal-price-note">Market price may vary slightly</span>
        </div>

        <!-- ACTIONS -->
        <div class="pmodal-actions">

          <button id="pmodal-cart" class="pmodal-cart">
            Add to Cart
          </button>

          <button id="pmodal-enquiry" class="pmodal-enquiry">
            Quick Enquiry
          </button>

        </div>

      </div>

    </div>

  </div>
</div>

<style>
.pmodal {
  position:fixed;
  inset:0;
  z-index:9999;
  display:none;
}

.pmodal.active {
  display:block;
}

/* OVERLAY */
.pmodal-overlay {
  position:absolute;
  inset:0;
  background:rgba(0,0,0,.65);
  backdrop-filter:blur(6px);
}

/* CONTAINER */
.pmodal-container {
  position:relative;
  max-width:1100px;
  margin:5vh auto;
  background:#fff;
  border-radius:20px;
  overflow:hidden;
  box-shadow:0 40px 120px rgba(0,0,0,.35);
  animation:modalIn .35s ease;
}

@keyframes modalIn {
  from { transform:translateY(40px); opacity:0 }
  to   { transform:translateY(0); opacity:1 }
}

/* CLOSE */
.pmodal-close {
  position:absolute;
  top:16px;
  right:16px;
  background:#fff;
  border:none;
  width:38px;
  height:38px;
  border-radius:50%;
  font-size:1.1rem;
  cursor:pointer;
  z-index:2;
}

/* LAYOUT */
.pmodal-content {
  display:grid;
  grid-template-columns:1fr 1fr;
}

/* MEDIA */
.pmodal-media {
  background:#F9FAFB;
  display:flex;
  align-items:center;
  justify-content:center;
  padding:2rem;
}

.pmodal-media img {
  max-width:100%;
  max-height:420px;
  object-fit:contain;
}

/* INFO */
.pmodal-info {
  padding:2.5rem;
  display:flex;
  flex-direction:column;
  gap:1.5rem;
}

/* HEADER */
.pmodal-brand {
  font-size:.75rem;
  font-weight:700;
  text-transform:uppercase;
  color:#9CA3AF;
}

.pmodal-title {
  font-size:1.4rem;
  font-weight:900;
  line-height:1.3;
}

/* SPECS */
.pmodal-specs {
  display:flex;
  flex-wrap:wrap;
  gap:.6rem;
}

.pmodal-spec {
  background:#F3F4F6;
  padding:.5rem .8rem;
  border-radius:6px;
  font-size:.75rem;
  font-weight:600;
}

/* PRICE */
.pmodal-price {
  font-size:2rem;
  font-weight:900;
  color:#CC1417;
}

.pmodal-price-note {
  font-size:.7rem;
  color:#6B7280;
}

/* ACTIONS */
.pmodal-actions {
  display:flex;
  gap:10px;
  margin-top:1rem;
}

.pmodal-cart {
  flex:1;
  background:#CC1417;
  color:#fff;
  border:none;
  padding:1rem;
  border-radius:10px;
  font-weight:800;
  cursor:pointer;
}

.pmodal-enquiry {
  flex:1;
  background:#fff;
  border:2px solid #E5E7EB;
  padding:1rem;
  border-radius:10px;
  font-weight:700;
  cursor:pointer;
}

/* MOBILE */
@media(max-width:900px) {
  .pmodal-content {
    grid-template-columns:1fr;
  }
}
</style>

<script>
let currentProduct = null;

const modal = document.getElementById('product-modal');

window.addEventListener('open-product-modal', (e) => {
  const p = e.detail;
  currentProduct = p;

  document.getElementById('pmodal-name').textContent = p.name;
  document.getElementById('pmodal-brand').textContent = p.brand;
  document.getElementById('pmodal-image').src = p.image || '';
  document.getElementById('pmodal-price').textContent = p.price || 'Request Price';

  const specs = [];
  if (p.capacity) specs.push(p.capacity);
  if (p.type) specs.push(p.type);

  document.getElementById('pmodal-specs').innerHTML =
    specs.map(s => `<div class="pmodal-spec">${s}</div>`).join('');

  modal.classList.add('active');
  document.body.style.overflow = 'hidden';
});

/* CLOSE */
document.getElementById('pmodal-close').onclick =
document.getElementById('pmodal-close-btn').onclick = () => {
  modal.classList.remove('active');
  document.body.style.overflow = '';
};

/* ACTIONS */
document.getElementById('pmodal-enquiry').onclick = () => {
  if (!currentProduct) return;

  const msg = encodeURIComponent(
    `Hello TECIL Solar, I'm interested in ${currentProduct.name}.`
  );

  window.open(`https://wa.me/2348037135545?text=${msg}`, '_blank');
};

document.getElementById('pmodal-cart').onclick = () => {
  alert('Cart system coming in Phase 3');
};
</script>