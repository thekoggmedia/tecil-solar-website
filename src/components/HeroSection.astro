---
import { heroStats, heroTrust } from '../data/site';
---
<section class="hero">
  <div class="hero-grid"></div>
  <div class="hero-orb a"></div>
  <div class="hero-orb b"></div>

  <div class="hero-orbital" aria-hidden="true">
    <svg viewBox="0 0 700 700" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="og" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#CC1417"/><stop offset="100%" stop-color="#E8601A"/>
        </linearGradient>
      </defs>
      <g><animateTransform attributeName="transform" type="rotate" from="0 350 350" to="360 350 350" dur="60s" repeatCount="indefinite"/>
        <circle cx="350" cy="350" r="290" fill="none" stroke="url(#og)" stroke-width="1" stroke-dasharray="14 20"/>
      </g>
      <g><animateTransform attributeName="transform" type="rotate" from="0 350 350" to="-360 350 350" dur="40s" repeatCount="indefinite"/>
        <circle cx="350" cy="350" r="210" fill="none" stroke="#E8601A" stroke-width="1" stroke-dasharray="6 22" opacity=".65"/>
      </g>
      <g><animateTransform attributeName="transform" type="rotate" from="0 350 350" to="360 350 350" dur="25s" repeatCount="indefinite"/>
        <circle cx="350" cy="350" r="135" fill="none" stroke="#CC1417" stroke-width="1" stroke-dasharray="4 14" opacity=".45"/>
      </g>
      <circle cx="350" cy="350" r="52" fill="none" stroke="rgba(232,96,26,.45)" stroke-width="1.5"/>
      <circle cx="350" cy="350" r="26" fill="rgba(232,96,26,.10)"/>
      <g opacity=".38">
        <line x1="350" y1="288" x2="350" y2="264" stroke="#E8601A" stroke-width="2"/>
        <line x1="350" y1="412" x2="350" y2="436" stroke="#E8601A" stroke-width="2"/>
        <line x1="288" y1="350" x2="264" y2="350" stroke="#E8601A" stroke-width="2"/>
        <line x1="412" y1="350" x2="436" y2="350" stroke="#E8601A" stroke-width="2"/>
      </g>
      <circle cx="640" cy="350" r="10" fill="#E8601A" opacity=".9">
        <animateTransform attributeName="transform" type="rotate" from="0 350 350" to="360 350 350" dur="60s" repeatCount="indefinite"/>
      </circle>
      <circle cx="560" cy="350" r="6" fill="#CC1417" opacity=".72">
        <animateTransform attributeName="transform" type="rotate" from="80 350 350" to="-280 350 350" dur="40s" repeatCount="indefinite"/>
      </circle>
    </svg>
  </div>

  <div class="container hero-shell">
    <div class="hero-copy reveal">
      <span class="section-tag" style="color:#E8601A">
        <span style="background:#E8601A;display:inline-block;width:22px;height:2px;flex-shrink:0"></span>
        Nigeria's Trusted Solar Authority — Est. 2008
      </span>

      <h1>
        <span class="line-white">POWER</span>
        <span class="line-stroke">WITHOUT</span>
        <span class="line-orange">COMPROMISE.</span>
      </h1>

      <p class="hero-lead">
        End-to-end solar energy solutions for homes, businesses, and institutions
        across Nigeria — delivered with precision and backed by 16 years of proven results.
      </p>

      <div class="hero-actions">
        <a href="/contact" class="btn-primary">
          Get a Free Quote
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/projects" class="btn-outline-white">View Our Projects</a>
        <a href="https://wa.me/2348037135545" target="_blank" class="btn-whatsapp">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>

      <div class="hero-locations">
        {heroTrust.map(c => <span>{c}</span>)}
      </div>
    </div>
  </div>

  <div class="hero-stats-bar">
    {heroStats.map((s, i) => (
      <>
        {i > 0 && <div class="hs-div"></div>}
        <div class="hs">
          <strong class="hs-val" data-target={s.value.replace(/\D/g,'')} data-suffix={s.value.replace(/\d/g,'')}>0</strong>
          <span class="hs-label">{s.label}</span>
        </div>
      </>
    ))}
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <div class="sh-line"></div><span>Scroll</span>
  </div>
</section>

<style>
.hero {
  position: relative; overflow: hidden;
  min-height: 100vh; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: #0F1117; padding: 72px 0 0;
}
.hero-grid {
  position: absolute; inset: 0; pointer-events: none;
  background-image:
    linear-gradient(rgba(204,20,23,.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(204,20,23,.05) 1px, transparent 1px);
  background-size: 60px 60px;
}
.hero-orb { position: absolute; border-radius: 50%; filter: blur(90px); pointer-events: none; }
.hero-orb.a { width:600px;height:600px; top:-120px;right:-60px; background:radial-gradient(circle,rgba(204,20,23,.12) 0%,transparent 70%); animation:orbFloat 9s ease-in-out infinite; }
.hero-orb.b { width:380px;height:380px; bottom:100px;left:-40px; background:radial-gradient(circle,rgba(232,96,26,.09) 0%,transparent 70%); animation:orbFloat 12s ease-in-out infinite reverse; }

.hero-orbital { position:absolute; right:-3%;top:50%;transform:translateY(-50%); width:min(50vw,620px);height:min(50vw,620px); opacity:.22; pointer-events:none; }
.hero-orbital svg { width:100%;height:100%; }

.hero-shell { position:relative;z-index:2; padding-bottom:5rem; width:100%; }
.hero-copy  { max-width:660px; }

h1 { display:flex;flex-direction:column; margin:0.8rem 0 1.5rem; animation:fadeUp .8s .15s ease both; }
.line-white  { color:#fff; }
.line-stroke { color:transparent; -webkit-text-stroke:2px #CC1417; }
.line-orange { color:#E8601A; }

.hero-lead {
  font-size:1.06rem; line-height:1.8; color:rgba(255,255,255,.58);
  max-width:52ch; margin-bottom:2rem;
  animation:fadeUp .8s .30s ease both;
  font-variation-settings:'wdth' 100,'wght' 400;
}
.hero-actions { display:flex;gap:.75rem;flex-wrap:wrap; animation:fadeUp .8s .45s ease both; }

.hero-locations {
  display:flex;flex-wrap:wrap;gap:.5rem;margin-top:1.75rem;
  animation:fadeUp .8s .6s ease both;
}
.hero-locations span {
  font-size:.72rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;
  color:rgba(255,255,255,.38);padding:.3rem .85rem;
  border:1px solid rgba(255,255,255,.10);border-radius:999px;
  font-variation-settings:'wdth' 100,'wght' 600;
}

.hero-stats-bar {
  position:absolute;bottom:0;left:0;right:0;
  display:flex;align-items:center;justify-content:center;
  background:rgba(255,255,255,.04);border-top:1px solid rgba(232,96,26,.16);
  backdrop-filter:blur(12px);padding:1.35rem 5%;z-index:2;
  animation:fadeIn .8s .9s ease both;flex-wrap:wrap;gap:.5rem;
}
.hs { display:flex;flex-direction:column;align-items:center;gap:3px;padding:0 2.5rem; }
.hs-val {
  font-family:'Nunito Sans',sans-serif;font-size:2.1rem;color:#fff;line-height:1;
  font-variation-settings:'wdth' 125,'wght' 900;
}
.hs-label { font-size:.63rem;font-weight:600;color:rgba(255,255,255,.35);letter-spacing:.08em;text-transform:uppercase; font-variation-settings:'wdth' 100,'wght' 600; }
.hs-div { width:1px;height:36px;background:rgba(204,20,23,.25); }

.scroll-hint { position:absolute;bottom:6rem;left:5%;display:flex;flex-direction:column;align-items:flex-start;gap:6px;z-index:2;animation:fadeIn 1s 1.1s ease both; }
.sh-line { width:1px;height:48px;background:linear-gradient(to bottom,transparent,#E8601A);animation:scrollPulse 2s ease-in-out infinite; }
.scroll-hint span { font-size:.6rem;font-weight:600;color:rgba(255,255,255,.25);letter-spacing:.2em;text-transform:uppercase; font-variation-settings:'wdth' 100,'wght' 600; }

@media(max-width:900px){ .hero-orbital{display:none} .line-stroke{-webkit-text-stroke:1.5px #CC1417} .hero-stats-bar{padding:1rem} .hs{padding:0 1rem} .hs-div{display:none} .scroll-hint{display:none} }
@media(max-width:480px){ .hero-actions{flex-direction:column} }
</style>
<script>
function countUp(){
  document.querySelectorAll('.hs-val').forEach(el=>{
    const t=parseInt(el.getAttribute('data-target')||'0');
    const sfx=el.getAttribute('data-suffix')||'';
    if((el as HTMLElement).dataset.done) return;
    (el as HTMLElement).dataset.done='1';
    let c=0;const step=Math.max(t/50,.2);
    const timer=setInterval(()=>{ c+=step; if(c>=t){c=t;clearInterval(timer);} el.textContent=Math.floor(c)+sfx; },22);
  });
}
document.addEventListener('DOMContentLoaded',()=>{
  const el=document.querySelector('.hero-stats-bar');
  if(!el) return;
  const io=new IntersectionObserver(e=>{ e.forEach(x=>{ if(x.isIntersecting){countUp();io.disconnect();} }); },{threshold:.1});
  io.observe(el);
  setTimeout(()=>{ const r=el.getBoundingClientRect(); if(r.top<window.innerHeight) countUp(); },600);
});
</script>
