---
/**
 * FLAGSHIP HERO SECTION (Premium + Balanced + Conversion Optimized)
 */

const slides = [
  { src: "/gallery/home/slide-01.webp" },
  { src: "/gallery/home/slide-02.webp" },
  { src: "/gallery/home/slide-03.webp" },
];
---

<section class="hero" id="hero">

  <!-- BACKGROUND -->
  <div class="hero-bg" aria-hidden="true">
    {slides.map((s, i) => (
      <div class={`hero-slide ${i === 0 ? "active" : ""}`}>
        <img 
          src={s.src} 
          alt="" 
          loading={i === 0 ? "eager" : "lazy"} 
          decoding="async"
        />
      </div>
    ))}
  </div>

  <!-- OVERLAY -->
  <div class="hero-overlay"></div>
  <div class="hero-glow"></div>

  <!-- CONTENT -->
  <div class="container hero-grid">

    <!-- LEFT -->
    <div class="hero-left">

      <span class="hero-pretitle">
        Trusted Solar Solutions Since 2008
      </span>

      <h1 class="hero-title">
        Reliable Solar Power  
        <span>Across Nigeria</span>
      </h1>

      <p class="hero-sub">
        We design and install high-performance solar, inverter, and backup systems 
        that eliminate downtime and reduce energy costs — trusted by homes, businesses, 
        and institutions nationwide.
      </p>

      <!-- CTA -->
      <div class="hero-cta">
        <a href="/contact" class="btn-primary">Get Free Consultation</a>
        <a href="/projects" class="btn-secondary">View Projects</a>
      </div>

      <!-- TRUST STRIP -->
      <div class="hero-trust">
        <span>✔ Free site assessment</span>
        <span>✔ Nationwide service</span>
        <span>✔ Fast installation</span>
      </div>

    </div>

    <!-- RIGHT -->
    <div class="hero-right" id="hero-stats">

      <div class="trust-panel">

        <div class="trust-header">
          <h3>Why Clients Choose Us</h3>
          <p>Proven performance across residential and commercial projects</p>
        </div>

        <div class="trust-card">
          <div class="trust-top">
            <div class="icon-wrap">⚡</div>
            <strong><span class="counter" data-target="16">0</span>+</strong>
          </div>
          <p>Years of solar engineering experience</p>
        </div>

        <div class="trust-card">
          <div class="trust-top">
            <div class="icon-wrap">📍</div>
            <strong><span class="counter" data-target="7">0</span></strong>
          </div>
          <p>Branches across Nigeria</p>
        </div>

        <div class="trust-card">
          <div class="trust-top">
            <div class="icon-wrap">🔧</div>
            <strong><span class="counter" data-target="1000">0</span>+</strong>
          </div>
          <p>Installations completed successfully</p>
        </div>

      </div>

    </div>

  </div>
</section>

<style>
/* ===== HERO BASE ===== */
.hero {
  position: relative;
  height: clamp(560px, 92vh, 820px);
  overflow: hidden;
  color: #fff;
}

/* ===== BACKGROUND ===== */
.hero-bg { position:absolute; inset:0; }

.hero-slide {
  position:absolute; inset:0;
  opacity:0;
  transform:scale(1.1);
  transition:opacity 1.2s ease, transform 8s ease;
}

.hero-slide.active {
  opacity:1;
  transform:scale(1);
}

.hero-slide img {
  width:100%; height:100%;
  object-fit:cover;
}

/* ===== OVERLAY ===== */
.hero-overlay {
  position:absolute; inset:0;
  background:
    linear-gradient(to bottom, rgba(0,0,0,.55), rgba(0,0,0,.85));
}

/* subtle brand glow */
.hero-glow {
  position:absolute;
  width:600px;
  height:600px;
  background: radial-gradient(circle, rgba(255,77,79,.25), transparent 70%);
  top:20%;
  left:10%;
  filter: blur(80px);
  opacity:.6;
}

/* ===== GRID ===== */
.hero-grid {
  position:relative;
  z-index:2;
  height:100%;

  display:grid;
  grid-template-columns: 1.1fr 0.9fr;
  align-items:center;
  gap:3rem;
}

/* ===== LEFT ===== */
.hero-left {
  max-width:640px;
}

/* PRETITLE */
.hero-pretitle {
  display:inline-block;
  font-size:.8rem;
  letter-spacing:.08em;
  text-transform:uppercase;
  color:rgba(255,255,255,.7);
  margin-bottom:.8rem;
}

/* TITLE */
.hero-title {
  font-size: clamp(2.6rem,5vw,4rem);
  font-weight:800;
  line-height:1.1;
  margin-bottom:1rem;
}

.hero-title span {
  display:block;
  background:linear-gradient(90deg,#ff4d4f,#ff8a00);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
}

/* SUBTEXT */
.hero-sub {
  font-size:1.05rem;
  line-height:1.6;
  color:rgba(255,255,255,.85);
  margin-bottom:2rem;
}

/* CTA */
.hero-cta {
  display:flex;
  gap:1rem;
  flex-wrap:wrap;
  margin-bottom:1.2rem;
}

.btn-primary {
  background:#cc1417;
  padding:1rem 1.6rem;
  border-radius:8px;
  color:#fff;
  font-weight:600;
  text-decoration:none;
  box-shadow:0 10px 25px rgba(204,20,23,.4);
  transition:.25s;
}

.btn-primary:hover {
  transform:translateY(-2px);
  background:#a90f12;
}

.btn-secondary {
  border:1px solid rgba(255,255,255,.35);
  padding:1rem 1.6rem;
  border-radius:8px;
  color:#fff;
  text-decoration:none;
}

.btn-secondary:hover {
  background:rgba(255,255,255,.08);
}

/* TRUST STRIP */
.hero-trust {
  display:flex;
  gap:1rem;
  flex-wrap:wrap;
  font-size:.8rem;
  color:rgba(255,255,255,.7);
}

/* ===== RIGHT PANEL ===== */
.hero-right {
  display:flex;
  justify-content:flex-end;
}

.trust-panel {
  width:100%;
  max-width:440px;

  display:flex;
  flex-direction:column;
  gap:1rem;

  padding:1.6rem;
  border-radius:16px;

  background:rgba(20,24,35,.65);
  backdrop-filter:blur(16px);
  border:1px solid rgba(255,255,255,.08);
}

/* HEADER */
.trust-header h3 {
  font-size:1rem;
  margin-bottom:.2rem;
}

.trust-header p {
  font-size:.75rem;
  color:rgba(255,255,255,.6);
}

/* CARDS */
.trust-card {
  padding:1rem;
  border-radius:12px;

  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.06);

  transition:.25s;
}

.trust-card:hover {
  transform:translateY(-4px);
  border-color:rgba(255,255,255,.2);
}

/* TOP */
.trust-top {
  display:flex;
  align-items:center;
  justify-content:space-between;
  margin-bottom:.4rem;
}

.icon-wrap {
  width:34px;
  height:34px;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:50%;
  background:rgba(255,255,255,.08);
  font-size:.9rem;
}

.trust-card strong {
  font-size:1.5rem;
  font-weight:800;
}

.trust-card p {
  font-size:.8rem;
  color:rgba(255,255,255,.7);
}

/* ===== MOBILE ===== */
@media(max-width:900px){
  .hero-grid {
    grid-template-columns:1fr;
    gap:2rem;
  }

  .hero-right {
    justify-content:flex-start;
  }

  .trust-panel {
    max-width:100%;
  }
}

/* REDUCE MOTION */
@media (prefers-reduced-motion: reduce) {
  .hero-slide {
    transition:none;
  }
}
</style>

<script>
/* ===== SLIDER ===== */
const slides = document.querySelectorAll(".hero-slide");
let i = 0;

setInterval(() => {
  slides[i].classList.remove("active");
  i = (i + 1) % slides.length;
  slides[i].classList.add("active");
}, 6500);

/* ===== COUNTERS ===== */
const counters = document.querySelectorAll(".counter");

function animateCounter(el) {
  const target = +el.dataset.target;
  let count = 0;
  const step = target / 80;

  function update() {
    count += step;
    if (count < target) {
      el.textContent = Math.floor(count);
      requestAnimationFrame(update);
    } else {
      el.textContent = target.toLocaleString();
    }
  }

  update();
}

const observer = new IntersectionObserver((entries, obs) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      counters.forEach(c => animateCounter(c));
      obs.disconnect();
    }
  });
}, { threshold: 0.5 });

observer.observe(document.getElementById("hero-stats"));
</script>