---
import { heroStats, heroTrust } from '../data/site';
---

<section class="hero-section">
  <div class="hero-grid"></div>
  <div class="hero-orb orb-a"></div>
  <div class="hero-orb orb-b"></div>

  <div class="container hero-shell">
    <div class="hero-copy reveal">
      <span class="section-tag">Energy That Performs</span>
      <h1>Powering Homes & Businesses Across Nigeria</h1>
      <p class="hero-lead">
        Reliable solar and inverter systems designed to reduce downtime, lower energy costs, and keep your operations moving.
      </p>

      <div class="hero-actions">
        <a href="/contact" class="btn-primary">
          Get a Free Quote
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </a>
        <a href="/products" class="btn-outline-white">View Products</a>
      </div>

      <div class="hero-pill-row">
        <span>Installation</span>
        <span>Maintenance</span>
        <span>Supply</span>
        <span>Projects</span>
      </div>

      <div class="hero-trust">
        {heroTrust.map((item) => <span>{item}</span>)}
      </div>
    </div>

    <div class="hero-visual reveal reveal-delay-2">
      <div class="hero-panel main">
        <div class="panel-top">
          <span>Nationwide reach</span>
          <strong>Operating since 2008</strong>
        </div>

        <div class="panel-wave">
          <div></div><div></div><div></div><div></div>
        </div>

        <div class="panel-copy">
          <h3>Structured for performance</h3>
          <p>
            Clean design, stronger visual hierarchy, and a premium feel that supports the brand instead of hiding it.
          </p>
        </div>
      </div>

      <div class="hero-side">
        <div class="hero-mini">
          <span>Coverage</span>
          <strong>Lagos • Port Harcourt • Calabar • Uyo • Ikom</strong>
        </div>
        <div class="hero-mini alt">
          <span>Support</span>
          <strong>Supply, installation, maintenance, and aftercare</strong>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-stats">
    {heroStats.map((item) => (
      <div class="stat-card">
        <strong>{item.value}</strong>
        <span>{item.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: calc(100vh - 84px);
    overflow: hidden;
    background:
      radial-gradient(circle at top right, rgba(204,20,23,0.22), transparent 28%),
      radial-gradient(circle at bottom left, rgba(232,96,26,0.10), transparent 24%),
      #0F1117;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 72px 72px;
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
    animation: drift 10s ease-in-out infinite;
  }

  .orb-a {
    width: 520px;
    height: 520px;
    top: -120px;
    right: -120px;
    background: radial-gradient(circle, rgba(204,20,23,0.22) 0%, transparent 72%);
  }

  .orb-b {
    width: 320px;
    height: 320px;
    bottom: 80px;
    left: -90px;
    background: radial-gradient(circle, rgba(232,96,26,0.14) 0%, transparent 72%);
    animation-direction: reverse;
  }

  .hero-shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: 4rem;
    align-items: center;
    padding-top: 5.5rem;
    padding-bottom: 7.5rem;
  }

  .hero-copy h1 {
    max-width: 9ch;
    color: #fff;
    margin-top: 0.6rem;
  }

  .hero-lead {
    max-width: 60ch;
    margin-top: 1.2rem;
    font-size: 1.08rem;
    color: rgba(255,255,255,0.68);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  .hero-pill-row,
  .hero-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .hero-pill-row {
    margin-top: 1.5rem;
  }

  .hero-pill-row span,
  .hero-trust span {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 0.9rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .hero-pill-row span {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.80);
  }

  .hero-trust {
    margin-top: 1rem;
  }

  .hero-trust span {
    background: rgba(232,96,26,0.10);
    border: 1px solid rgba(232,96,26,0.24);
    color: #FFBA84;
  }

  .hero-visual {
    display: grid;
    gap: 1rem;
  }

  .hero-panel,
  .hero-mini {
    border-radius: 28px;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(16px);
    box-shadow: 0 24px 60px rgba(0,0,0,0.22);
  }

  .hero-panel.main {
    padding: 1.35rem;
    min-height: 400px;
  }

  .panel-top {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    color: rgba(255,255,255,0.7);
  }

  .panel-top span {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.48);
  }

  .panel-top strong {
    font-family: var(--font-display);
    font-size: 2.1rem;
    color: #fff;
    text-transform: uppercase;
  }

  .panel-wave {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.8rem;
    margin-top: 1.4rem;
  }

  .panel-wave div {
    height: 160px;
    border-radius: 20px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.10)),
      linear-gradient(180deg, rgba(232,96,26,0.18), rgba(204,20,23,0.32));
    border: 1px solid rgba(255,255,255,0.10);
    position: relative;
    overflow: hidden;
  }

  .panel-wave div::after {
    content: '';
    position: absolute;
    inset: auto 0 0 0;
    height: 40%;
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.2));
  }

  .panel-wave div:nth-child(2) { height: 210px; }
  .panel-wave div:nth-child(3) { height: 120px; }
  .panel-wave div:nth-child(4) { height: 180px; }

  .panel-copy {
    margin-top: 1.2rem;
  }

  .panel-copy h3 {
    color: #fff;
    font-size: 1.6rem;
  }

  .panel-copy p {
    margin-top: 0.55rem;
    color: rgba(255,255,255,0.68);
  }

  .hero-side {
    display: grid;
    gap: 1rem;
  }

  .hero-mini {
    padding: 1.2rem 1.2rem 1.15rem;
  }

  .hero-mini span {
    display: block;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.46);
  }

  .hero-mini strong {
    display: block;
    margin-top: 0.45rem;
    font-size: 1.2rem;
    line-height: 1.35;
    color: #fff;
  }

  .hero-mini.alt {
    background: rgba(255,255,255,0.10);
  }

  .hero-stats {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: rgba(255,255,255,0.08);
    border-top: 1px solid rgba(255,255,255,0.10);
  }

  .stat-card {
    padding: 1.4rem 1rem;
    background: rgba(255,255,255,0.04);
    text-align: center;
  }

  .stat-card strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2.55rem;
    color: #fff;
    line-height: 1;
  }

  .stat-card span {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.48);
  }

  @keyframes drift {
    0%, 100% { transform: translateY(0px) scale(1); }
    50% { transform: translateY(-18px) scale(1.02); }
  }

  @media (max-width: 980px) {
    .hero-shell {
      grid-template-columns: 1fr;
      gap: 2.3rem;
    }

    .hero-copy h1 {
      max-width: 12ch;
    }
  }

  @media (max-width: 720px) {
    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-panel.main {
      min-height: 360px;
    }

    .panel-wave {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .hero-stats {
      grid-template-columns: 1fr;
    }

    .hero-panel.main {
      padding: 1rem;
    }
  }
</style>