---
// HeroSection.astro — Full screen animated hero
---

<section class="hero" id="hero">

  <!-- Animated background grid -->
  <div class="hero-grid"></div>

  <!-- Glowing orb effects — red/orange -->
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <!-- Orbital SVG graphic -->
  <div class="hero-orbital" aria-hidden="true">
    <svg viewBox="0 0 700 700" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="og1" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#CC1417"/>
          <stop offset="100%" stop-color="#E8601A"/>
        </linearGradient>
      </defs>
      <circle cx="350" cy="350" r="290" fill="none" stroke="url(#og1)" stroke-width="1" stroke-dasharray="14 20" class="ring r1"/>
      <circle cx="350" cy="350" r="210" fill="none" stroke="#E8601A" stroke-width="1" stroke-dasharray="6 22" class="ring r2"/>
      <circle cx="350" cy="350" r="135" fill="none" stroke="#CC1417" stroke-width="1" stroke-dasharray="4 18" class="ring r3"/>
      <circle cx="350" cy="350" r="52" fill="none" stroke="rgba(232,96,26,0.5)" stroke-width="1.5"/>
      <circle cx="350" cy="350" r="28" fill="rgba(232,96,26,0.1)"/>
      <g opacity="0.35">
        <line x1="350" y1="290" x2="350" y2="262" stroke="#E8601A" stroke-width="2"/>
        <line x1="350" y1="410" x2="350" y2="438" stroke="#E8601A" stroke-width="2"/>
        <line x1="290" y1="350" x2="262" y2="350" stroke="#E8601A" stroke-width="2"/>
        <line x1="410" y1="350" x2="438" y2="350" stroke="#E8601A" stroke-width="2"/>
        <line x1="309" y1="309" x2="291" y2="291" stroke="#E8601A" stroke-width="1.5"/>
        <line x1="391" y1="309" x2="409" y2="291" stroke="#E8601A" stroke-width="1.5"/>
        <line x1="309" y1="391" x2="291" y2="409" stroke="#E8601A" stroke-width="1.5"/>
        <line x1="391" y1="391" x2="409" y2="409" stroke="#E8601A" stroke-width="1.5"/>
      </g>
      <circle cx="640" cy="350" r="10" fill="#E8601A" opacity="0.85">
        <animateTransform attributeName="transform" type="rotate" from="0 350 350" to="360 350 350" dur="55s" repeatCount="indefinite"/>
      </circle>
      <circle cx="560" cy="350" r="6" fill="#CC1417" opacity="0.7">
        <animateTransform attributeName="transform" type="rotate" from="80 350 350" to="-280 350 350" dur="35s" repeatCount="indefinite"/>
      </circle>
      <circle cx="485" cy="350" r="4" fill="#E8601A" opacity="0.5">
        <animateTransform attributeName="transform" type="rotate" from="200 350 350" to="-160 350 350" dur="22s" repeatCount="indefinite"/>
      </circle>
    </svg>
  </div>

  <!-- Main content -->
  <div class="hero-content">

    <div class="hero-badge">
      <span class="badge-dot"></span>
      Nigeria's Trusted Solar Authority — Est. 2008
    </div>

    <h1 class="hero-title">
      <span class="title-line">POWER</span>
      <span class="title-line title-stroke">WITHOUT</span>
      <span class="title-line title-orange">COMPROMISE.</span>
    </h1>

    <p class="hero-sub">
      End-to-end solar energy solutions across Nigeria. Residential homes, commercial enterprises,
      institutions, and government projects — delivered with precision since 2008.
    </p>

    <div class="hero-btns">
      <a href="/contact" class="btn-primary">
        Get a Free Quote
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/projects" class="btn-outline">View Our Projects</a>
      <a href="https://wa.me/2348037135545" target="_blank" class="btn-whatsapp">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        WhatsApp Us
      </a>
    </div>

    <div class="scroll-indicator">
      <div class="scroll-line"></div>
      <span>Scroll</span>
    </div>

  </div>

  <!-- Stats strip -->
  <div class="hero-stats">
    <div class="hero-stat">
      <div class="stat-row">
        <span class="stat-num" data-target="16">0</span><span class="stat-sfx">+</span>
      </div>
      <span class="stat-label">Years in Operation</span>
    </div>
    <div class="stat-divider"></div>
    <div class="hero-stat">
      <div class="stat-row">
        <span class="stat-num" data-target="7">0</span>
      </div>
      <span class="stat-label">Active Branches</span>
    </div>
    <div class="stat-divider"></div>
    <div class="hero-stat">
      <div class="stat-row">
        <span class="stat-num" data-target="34">0</span><span class="stat-sfx">+</span>
      </div>
      <span class="stat-label">Corporate Projects</span>
    </div>
    <div class="stat-divider"></div>
    <div class="hero-stat">
      <div class="stat-row">
        <span class="stat-num" data-target="15">0</span><span class="stat-sfx">+</span>
      </div>
      <span class="stat-label">Brand Partnerships</span>
    </div>
  </div>

</section>

<style>
  .hero {
    min-height: 100vh;
    background: #111111;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 72px 5% 0;
    position: relative;
    overflow: hidden;
  }

  .hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(204,20,23,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(204,20,23,0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    pointer-events: none;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(90px);
  }
  .orb-1 {
    width: 650px; height: 650px;
    background: radial-gradient(circle, rgba(204,20,23,0.11) 0%, transparent 70%);
    top: -120px; right: -80px;
    animation: orbFloat 9s ease-in-out infinite;
  }
  .orb-2 {
    width: 420px; height: 420px;
    background: radial-gradient(circle, rgba(232,96,26,0.09) 0%, transparent 70%);
    bottom: 80px; left: -60px;
    animation: orbFloat 12s ease-in-out infinite reverse;
  }
  .orb-3 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, rgba(200,150,12,0.05) 0%, transparent 70%);
    top: 40%; left: 40%;
    animation: orbFloat 7s ease-in-out infinite 2s;
  }

  .hero-orbital {
    position: absolute;
    right: -4%; top: 50%;
    transform: translateY(-50%);
    width: min(52vw, 640px);
    height: min(52vw, 640px);
    opacity: 0.2;
    pointer-events: none;
  }
  .hero-orbital svg { width: 100%; height: 100%; }
  .ring { transform-origin: 350px 350px; }
  .r1 { animation: spin 65s linear infinite; }
  .r2 { animation: spinR 42s linear infinite; }
  .r3 { animation: spin 28s linear infinite; }

  .hero-content {
    text-align: left;
    max-width: 700px;
    width: 100%;
    position: relative;
    z-index: 2;
    padding-bottom: 6rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    color: #E8601A;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border: 1px solid rgba(232,96,26,0.28);
    border-radius: 100px;
    padding: 6px 14px;
    margin-bottom: 2rem;
    background: rgba(232,96,26,0.06);
    animation: fadeUp 0.8s ease forwards;
  }

  .badge-dot {
    width: 6px; height: 6px;
    background: #E8601A;
    border-radius: 50%;
    animation: pulse-dot 2s infinite;
  }

  .hero-title {
    display: flex;
    flex-direction: column;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(4rem, 11vw, 9rem);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin-bottom: 1.75rem;
    animation: fadeUp 0.8s ease 0.15s both;
  }

  .title-line { color: #ffffff; }
  .title-stroke {
    color: transparent;
    -webkit-text-stroke: 2px #CC1417;
  }
  .title-orange { color: #E8601A; }

  .hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.55);
    max-width: 520px;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.8s ease 0.3s both;
  }

  .hero-btns {
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
    animation: fadeUp 0.8s ease 0.45s both;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 7rem; left: 0;
    display: flex; flex-direction: column;
    align-items: flex-start; gap: 8px;
    animation: fadeIn 1s ease 1.2s both;
  }
  .scroll-line {
    width: 1px; height: 52px;
    background: linear-gradient(to bottom, transparent, #E8601A);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  .scroll-indicator span {
    font-family: 'Inter', sans-serif;
    font-size: 0.62rem;
    color: rgba(255,255,255,0.25);
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  /* Stats strip */
  .hero-stats {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.025);
    border-top: 1px solid rgba(232,96,26,0.15);
    backdrop-filter: blur(12px);
    padding: 1.5rem 5%;
    z-index: 2;
    animation: fadeIn 0.8s ease 0.9s both;
  }

  .hero-stat {
    display: flex; flex-direction: column;
    align-items: center; gap: 4px;
    padding: 0 3rem;
  }

  .stat-row {
    display: flex; align-items: baseline;
    line-height: 1;
  }

  .stat-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 2.2rem;
    font-weight: 900;
    color: #ffffff;
    line-height: 1;
  }

  .stat-sfx {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
    color: #E8601A;
    margin-left: 2px;
  }

  .stat-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.68rem;
    font-weight: 500;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-align: center;
  }

  .stat-divider {
    width: 1px; height: 40px;
    background: rgba(204,20,23,0.2);
  }

  @media (max-width: 900px) {
    .hero-orbital { display: none; }
    .hero-content { text-align: left; }
    .title-stroke { -webkit-text-stroke: 1px #CC1417; }
    .hero-stats { padding: 1rem 3%; flex-wrap: wrap; gap: 0.5rem; }
    .hero-stat { padding: 0.5rem 1.25rem; }
    .stat-divider { display: none; }
    .scroll-indicator { display: none; }
  }
  @media (max-width: 480px) {
    .hero-btns { flex-direction: column; }
    .hero-title { font-size: clamp(3rem, 14vw, 5rem); }
  }
</style>

<script>
  // Count-up stats
  const statsEl = document.querySelector('.hero-stats');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        document.querySelectorAll('.stat-num').forEach(el => {
          const target = parseInt(el.getAttribute('data-target') || '0');
          let current = 0;
          const step = target / 60;
          const timer = setInterval(() => {
            current += step;
            if (current >= target) { current = target; clearInterval(timer); }
            el.textContent = Math.floor(current).toString();
          }, 22);
        });
        observer.disconnect();
      }
    });
  }, { threshold: 0.5 });
  if (statsEl) observer.observe(statsEl);
</script>
