---
/**
 * TECIL SOLAR — Hero Section
 * Full-screen hero with background image slider,
 * animated counters, and brand-accurate copy.
 *
 * Images: /public/gallery/home/slide-01.webp → slide-06.webp
 * Add more slides simply by extending the slides array below.
 */

const slides = [
  { src: '/gallery/home/slide-01.webp', alt: 'TECIL Solar residential installation' },
  { src: '/gallery/home/slide-02.webp', alt: 'TECIL Solar commercial hybrid system' },
  { src: '/gallery/home/slide-03.webp', alt: 'TECIL Solar institutional project' },
  { src: '/gallery/home/slide-04.webp', alt: 'TECIL Solar engineers at work' },
  { src: '/gallery/home/slide-05.webp', alt: 'TECIL Solar street lighting project' },
  { src: '/gallery/home/slide-06.webp', alt: 'TECIL Solar showroom Calabar' },
];

const stats = [
  {
    icon: '⚡',
    value: 16,
    suffix: '+',
    label: 'Years of solar engineering experience',
  },
  {
    icon: '🏗',
    value: 34,
    suffix: '+',
    label: 'Documented corporate projects since 2014',
  },
  {
    icon: '📍',
    value: 7,
    suffix: '',
    label: 'Active branches across 5 Nigerian states',
  },
];
---

<section class="hero" id="hero">

  <!-- ── BACKGROUND SLIDER ── -->
  <div class="hero-bg" aria-hidden="true">
    {slides.map((s, i) => (
      <div class={`hero-slide ${i === 0 ? 'active' : ''}`} data-index={i}>
        <img
          src={s.src}
          alt={s.alt}
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
        />
      </div>
    ))}
  </div>

  <!-- ── OVERLAYS ── -->
  <div class="hero-overlay"   aria-hidden="true"></div>
  <div class="hero-grid-mask" aria-hidden="true"></div>
  <div class="hero-glow-orb"  aria-hidden="true"></div>

  <!-- ── SLIDE PROGRESS BAR ── -->
  <div class="hero-progress" aria-hidden="true">
    <div class="hero-progress-fill" id="hero-progress-fill"></div>
  </div>

  <!-- ── CONTENT ── -->
  <div class="container hero-content-grid">

    <!-- LEFT — Copy + CTAs -->
    <div class="hero-left">

      <span class="hero-pretitle">
        <span class="hp-dot"></span>
        Nigeria's Trusted Solar Authority Since 2008
      </span>

      <h1 class="hero-title">
        Reliable Power.<br/>
        <span class="text-gradient">Expert Hands.</span>
      </h1>

      <p class="hero-sub">
        We design, supply, and install high-performance solar, inverter, and hybrid
        systems that eliminate downtime and reduce energy costs — for homes,
        businesses, and institutions across Nigeria.
      </p>

      <div class="hero-cta">
        <a href="/contact" class="btn-primary">
          Get a Free Quote
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/projects" class="btn-outline-white">
          View Our Projects
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <div class="hero-trust">
        <span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Free site assessment
        </span>
        <span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          7 branches nationwide
        </span>
        <span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#25D366" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          Authorised brands only
        </span>
      </div>

    </div>

    <!-- RIGHT — Stats Panel -->
    <div class="hero-right" id="hero-stats">
      <div class="trust-panel">

        <div class="trust-panel-header">
          <div class="tph-bar"></div>
          <div>
            <h3>Why Nigeria Trusts TECIL Solar</h3>
            <p>Proven delivery across residential, commercial, and institutional sectors</p>
          </div>
        </div>

        <div class="trust-cards">
          {stats.map((s, i) => (
            <div class={`trust-card tc-${i}`}>
              <div class="tc-left">
                <div class="tc-icon">{s.icon}</div>
                <p class="tc-label">{s.label}</p>
              </div>
              <div class="tc-value">
                <strong>
                  <span class="counter" data-target={s.value}>0</span>{s.suffix}
                </strong>
              </div>
            </div>
          ))}
        </div>

        <a href="/contact" class="trust-panel-cta">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          WhatsApp Us Now — Free Consultation
        </a>

      </div>
    </div>

  </div>

  <!-- ── SLIDE DOTS ── -->
  <div class="hero-dots" aria-hidden="true">
    {slides.map((_, i) => (
      <button class={`hero-dot ${i === 0 ? 'active' : ''}`} data-target={i} aria-label={`Slide ${i + 1}`}></button>
    ))}
  </div>

  <!-- ── SCROLL INDICATOR ── -->
  <div class="hero-scroll" aria-hidden="true">
    <div class="hs-line"></div>
    <span>Scroll</span>
  </div>

</section>

<style>
/* ══════════════════════════════════════
   HERO BASE
══════════════════════════════════════ */
.hero {
  position: relative;
  height: clamp(600px, 95vh, 900px);
  overflow: hidden;
  color: #fff;
  display: flex;
  align-items: center;
}

/* ══════════════════════════════════════
   BACKGROUND SLIDER
══════════════════════════════════════ */
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.hero-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transform: scale(1.06);
  transition:
    opacity 1.4s cubic-bezier(.4,0,.2,1),
    transform 9s cubic-bezier(.2,0,.8,1);
  will-change: opacity, transform;
}

.hero-slide.active {
  opacity: 1;
  transform: scale(1);
}

.hero-slide.leaving {
  opacity: 0;
  transform: scale(0.98);
}

.hero-slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Fallback dark background when no images loaded */
.hero-bg::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--dark);
  z-index: -1;
}

/* ══════════════════════════════════════
   OVERLAYS
══════════════════════════════════════ */
.hero-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background:
    linear-gradient(
      105deg,
      rgba(10, 12, 18, 0.88) 0%,
      rgba(10, 12, 18, 0.65) 45%,
      rgba(10, 12, 18, 0.72) 100%
    );
}

/* Subtle brand grid — matches page-hero across the site */
.hero-grid-mask {
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(204,20,23,0.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(204,20,23,0.05) 1px, transparent 1px);
  background-size: 72px 72px;
}

/* Warm red glow — top-right ambient light */
.hero-glow-orb {
  position: absolute;
  z-index: 1;
  width: 700px;
  height: 700px;
  top: -15%;
  right: -8%;
  background: radial-gradient(
    circle,
    rgba(204, 20, 23, 0.2) 0%,
    rgba(232, 96, 26, 0.08) 45%,
    transparent 70%
  );
  filter: blur(60px);
  pointer-events: none;
  animation: orbFloat 10s ease-in-out infinite;
}

/* ══════════════════════════════════════
   PROGRESS BAR
══════════════════════════════════════ */
.hero-progress {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: rgba(255,255,255,.08);
  z-index: 20;
}

.hero-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--red), var(--orange));
  width: 0%;
  transition: width linear;
}

/* ══════════════════════════════════════
   CONTENT GRID
══════════════════════════════════════ */
.hero-content-grid {
  position: relative;
  z-index: 10;
  width: 100%;
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  align-items: center;
  gap: 3rem;
  padding-top: 80px; /* offset for fixed nav */
}

/* ══════════════════════════════════════
   LEFT — COPY
══════════════════════════════════════ */
.hero-left {
  max-width: 640px;
}

/* PRE-TITLE */
.hero-pretitle {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: rgba(255,255,255,.65);
  margin-bottom: 1.1rem;
  font-variation-settings: 'wdth' 100, 'wght' 700;
}

.hp-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--orange);
  flex-shrink: 0;
  animation: pulseDot 2.5s ease-in-out infinite;
}

/* TITLE */
.hero-title {
  font-family: var(--font);
  font-size: clamp(3rem, 6.5vw, 6.5rem);
  font-weight: 900;
  line-height: 0.95;
  text-transform: uppercase;
  letter-spacing: .01em;
  color: #fff;
  margin-bottom: 1.25rem;
  font-variation-settings: 'wdth' 125, 'wght' 900;
}

/* SUBTEXT */
.hero-sub {
  font-size: 1.05rem;
  line-height: 1.75;
  color: rgba(255,255,255,.72);
  max-width: 56ch;
  margin-bottom: 2.25rem;
  font-variation-settings: 'wdth' 100, 'wght' 400;
}

/* CTAs */
.hero-cta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 1.75rem;
}

/* TRUST STRIP */
.hero-trust {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
}

.hero-trust span {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: .78rem;
  font-weight: 600;
  color: rgba(255,255,255,.65);
  letter-spacing: .02em;
  font-variation-settings: 'wdth' 100, 'wght' 600;
}

/* ══════════════════════════════════════
   RIGHT — STATS PANEL
══════════════════════════════════════ */
.hero-right {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.trust-panel {
  width: 100%;
  max-width: 420px;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 1.5rem;
  border-radius: 16px;
  background: rgba(12, 14, 22, 0.72);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,.08);
  box-shadow:
    0 24px 64px rgba(0,0,0,.4),
    inset 0 1px 0 rgba(255,255,255,.06);
}

/* PANEL HEADER */
.trust-panel-header {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding-bottom: 1rem;
  border-bottom: 1px solid rgba(255,255,255,.07);
}

.tph-bar {
  width: 3px;
  height: 36px;
  background: linear-gradient(to bottom, var(--red), var(--orange));
  border-radius: 3px;
  flex-shrink: 0;
  margin-top: 2px;
}

.trust-panel-header h3 {
  font-family: var(--font);
  font-size: .88rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: #fff;
  line-height: 1.3;
  margin-bottom: 3px;
  font-variation-settings: 'wdth' 125, 'wght' 800;
}

.trust-panel-header p {
  font-size: .72rem;
  color: rgba(255,255,255,.42);
  line-height: 1.5;
  max-width: none;
}

/* STAT CARDS */
.trust-cards {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.trust-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: .9rem 1rem;
  border-radius: 10px;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.06);
  transition: all .25s ease;
}

.trust-card:hover {
  background: rgba(204,20,23,.08);
  border-color: rgba(204,20,23,.25);
  transform: translateX(4px);
}

.tc-left {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
}

.tc-icon {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9px;
  background: rgba(255,255,255,.06);
  font-size: .9rem;
  flex-shrink: 0;
}

.tc-label {
  font-size: .75rem;
  color: rgba(255,255,255,.55);
  line-height: 1.4;
  max-width: none;
  font-variation-settings: 'wdth' 100, 'wght' 400;
}

.tc-value strong {
  font-family: var(--font);
  font-size: 1.75rem;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  white-space: nowrap;
  font-variation-settings: 'wdth' 125, 'wght' 900;
}

/* PANEL CTA */
.trust-panel-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: .85rem 1rem;
  border-radius: 10px;
  background: #25D366;
  color: #fff;
  font-size: .78rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .06em;
  text-decoration: none;
  transition: all .25s ease;
  box-shadow: 0 4px 18px rgba(37,211,102,.3);
  font-variation-settings: 'wdth' 100, 'wght' 800;
}

.trust-panel-cta:hover {
  background: #1DA851;
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(37,211,102,.4);
  color: #fff