<section class="cta-band">
  <div class="container cta-shell">
    <div class="cta-copy reveal">
      <span class="section-tag" style="color: rgba(255,255,255,0.72);">Ready to Go Solar?</span>
      <h2>Reliable power starts with a single call.</h2>
      <p>
        Talk to the team today. We will assess your load, suggest the right system, and give you a clear quote.
      </p>
    </div>

    <div class="cta-actions reveal reveal-delay-2">
      <a href="/contact" class="cta-main">Get Your Free Quote</a>
      <a href="/branches" class="btn-outline-white">Find a Branch</a>
      <div class="cta-proof">
        <span>Est. 2008</span>
        <span>7 service points</span>
        <span>34+ projects</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    overflow: hidden;
    padding: 5.5rem 0;
    background:
      radial-gradient(circle at top left, rgba(255,255,255,0.14), transparent 22%),
      linear-gradient(135deg, #CC1417, #A30F11 50%, #8E0D10);
  }

  .cta-band::before {
    content: 'TECIL';
    position: absolute;
    right: 3%;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-size: clamp(7rem, 18vw, 15rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: rgba(255,255,255,0.06);
    pointer-events: none;
  }

  .cta-shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
  }

  .cta-copy h2 {
    color: #fff;
    max-width: 10ch;
    margin-top: 0.6rem;
  }

  .cta-copy p {
    max-width: 52ch;
    margin-top: 0.9rem;
    color: rgba(255,255,255,0.78);
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: 0.95rem;
  }

  .cta-main {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 1.35rem;
    border-radius: 999px;
    background: #fff;
    color: var(--red);
    font-size: 0.84rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    box-shadow: 0 16px 32px rgba(0,0,0,0.14);
  }

  .cta-main:hover {
    transform: translateY(-2px);
  }

  .cta-proof {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .cta-proof span {
    padding: 0.62rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.18);
    background: rgba(255,255,255,0.08);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.72);
  }

  @media (max-width: 900px) {
    .cta-shell {
      grid-template-columns: 1fr;
    }

    .cta-copy h2 {
      max-width: 12ch;
    }
  }
</style>