<section class="cta-section">
  <div class="cta-bg"></div>
  <div class="cta-orb"></div>
  <div class="container cta-inner">
    <div class="cta-text reveal">
      <span class="section-tag">Ready to Go Solar?</span>
      <h2>Reliable Power Starts<br/>with a <span class="text-red-gradient">Single Call.</span></h2>
      <p>
        Talk to our technical team today. We'll assess your load, recommend the right system,
        and give you a clear, honest quote. No pressure. No nonsense.
      </p>
      <div class="cta-contacts">
        <a href="tel:+2348037135545" class="contact-chip">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.38a2 2 0 0 1 1.99-1.8h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17z"/></svg>
          0803 713 5545
        </a>
        <a href="https://wa.me/2348037135545" target="_blank" class="contact-chip contact-chip-wa">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          WhatsApp Us
        </a>
      </div>
    </div>
    <div class="cta-actions reveal reveal-delay-2">
      <a href="/contact" class="btn-primary cta-main-btn">
        Get Your Free Quote
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
      <a href="/branches" class="btn-outline">Find Nearest Branch</a>
      <div class="cta-est">Est. 2008 · 7 Branches · 5 States · 34+ Projects</div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    background: linear-gradient(135deg, #CC1417 0%, #A30F11 45%, #8b0c0e 100%);
    padding: 7rem 5%;
    position: relative; overflow: hidden;
  }
  .cta-bg {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .cta-bg::after {
    content: 'TECIL';
    position: absolute; right: 3%; top: 50%; transform: translateY(-50%);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(8rem, 18vw, 16rem); font-weight: 900;
    color: rgba(255,255,255,0.04); letter-spacing: -0.02em;
    pointer-events: none; line-height: 1;
  }
  .cta-orb {
    position: absolute; top: -100px; left: -100px;
    width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-inner {
    position: relative; z-index: 1;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 6rem; align-items: center;
  }
  .cta-text h2 { color: #fff; margin-bottom: 1rem; }
  .cta-text p { color: rgba(255,255,255,0.7); margin-bottom: 1.75rem; }
  .cta-contacts { display: flex; gap: 10px; flex-wrap: wrap; }
  .contact-chip {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff; text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem; font-weight: 600;
    padding: 7px 14px; border-radius: 3px;
    transition: all 0.3s ease;
  }
  .contact-chip:hover { background: rgba(255,255,255,0.2); color: #fff; }
  .contact-chip-wa {
    background: rgba(37,211,102,0.12) !important;
    border-color: rgba(37,211,102,0.3) !important;
    color: #25D366 !important;
  }
  .contact-chip-wa:hover { background: #25D366 !important; color: #fff !important; }

  .cta-actions {
    display: flex; flex-direction: column; gap: 1rem; align-items: flex-start;
  }
  .cta-main-btn { background: #fff !important; color: #CC1417 !important; border-color: #fff !important; }
  .cta-main-btn:hover { background: transparent !important; color: #fff !important; }
  .cta-actions .btn-outline { border-color: rgba(255,255,255,0.4) !important; color: #fff !important; }
  .cta-actions .btn-outline:hover { border-color: #fff !important; color: #fff !important; }
  .cta-est {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem; font-weight: 500;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.06em;
  }

  @media (max-width: 900px) {
    .cta-inner { grid-template-columns: 1fr; gap: 3rem; }
    .cta-actions { align-items: stretch; }
  }
</style>
