<style>
.cta { background:linear-gradient(135deg,#CC1417 0%,#A30F11 45%,#8B0C0E 100%);padding:6rem 5%;position:relative;overflow:hidden; }
.cta-noise { position:absolute;inset:0;background-image:linear-gradient(rgba(255,255,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.04) 1px,transparent 1px);background-size:60px 60px;pointer-events:none; }
.cta-noise::after { content:'TECIL';position:absolute;right:2%;top:50%;transform:translateY(-50%);font-family:'Nunito Sans',sans-serif;font-size:clamp(8rem,18vw,16rem);font-weight:900;color:rgba(255,255,255,.04);letter-spacing:-.02em;pointer-events:none;font-variation-settings:'wdth' 125,'wght' 900; }
.cta-orb { position:absolute;top:-100px;left:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(255,255,255,.07) 0%,transparent 70%);pointer-events:none; }
.cta-shell { position:relative;z-index:1;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center; }
.cta-left h2 { color:rgba(255,255,255,.88);margin-bottom:.9rem; }
.cta-left p  { color:rgba(255,255,255,.68);margin-bottom:1.5rem; }
.cta-chips { display:flex;gap:10px;flex-wrap:wrap; }
.cc { display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);color:#fff;font-size:.8rem;font-weight:600;padding:7px 14px;border-radius:6px;text-decoration:none;transition:all .25s ease;font-variation-settings:'wdth' 100,'wght' 600; }
.cc:hover { background:rgba(255,255,255,.22);color:#fff; }
.cc-wa { background:rgba(37,211,102,.14) !important;border-color:rgba(37,211,102,.35) !important;color:#5aeb8a !important; }
.cc-wa:hover { background:#25D366 !important;color:#fff !important; }
.cta-right { display:flex;flex-direction:column;align-items:flex-start;gap:.9rem; }
.cta-main { display:inline-flex;align-items:center;gap:8px;padding:14px 28px;background:#fff;color:#CC1417;font-size:.84rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;border:2px solid #fff;border-radius:6px;text-decoration:none;transition:all .3s ease;font-variation-settings:'wdth' 100,'wght' 700; }
.cta-main:hover { background:transparent;color:#fff;transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,0,0,.2); }
.cta-proof { font-size:.7rem;font-weight:500;color:rgba(255,255,255,.38);letter-spacing:.06em;font-variation-settings:'wdth' 100,'wght' 500; }
@media(max-width:900px){ .cta-shell{grid-template-columns:1fr;gap:3rem} .cta-right{align-items:stretch} }
</style>
