---
const services = [
  {
    num: "01",
    title: "Professional Installation",
    desc: "End-to-end installation of solar, inverter backup, and hybrid systems for residential, commercial, and institutional clients. Every job documented with a signed commissioning report.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
    href: "/services#installation",
  },
  {
    num: "02",
    title: "Maintenance & Repair",
    desc: "Scheduled preventive maintenance and reactive repair services for all installed systems and third-party solar/inverter installations. SLAs available for commercial clients.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    href: "/services#maintenance",
  },
  {
    num: "03",
    title: "Load Assessment & Advisory",
    desc: "Pre-installation energy audits and load assessments to ensure right-sizing of systems. Includes ROI analysis, system design, and brand-neutral product advice.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
    href: "/services#assessment",
  },
  {
    num: "04",
    title: "Training & Capacity Building",
    desc: "Solar and inverter design, installation, and maintenance courses for internal staff and external participants. Evolving into the TECIL Solar Training Institute in 2026.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
    href: "/services#training",
  },
  {
    num: "05",
    title: "Large-Scale EPC Projects",
    desc: "Under TECIL Solar Projects — full Engineering, Procurement and Construction for government, institutional, and industrial clients. Fully documented, commissioned deliveries.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
    href: "/services#projects",
  },
  {
    num: "06",
    title: "Energy-as-a-Service (EaaS)",
    desc: "Access solar power without upfront capital outlay — in exchange for a monthly service or energy fee. In partnership with financing institutions. A major 2026–2028 growth offering.",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    href: "/services#eaas",
  },
];
---

<section class="services-section dark-section section" id="services">
  <div class="container">

    <div class="services-header">
      <span class="section-tag">What We Do</span>
      <h2>End-to-End <span class="text-red-gradient">Solar Services</span></h2>
      <p class="services-sub">
        From a single residential system to a 60KW off-grid industrial project — we handle everything in-house.
        Supply, design, install, maintain, train.
      </p>
    </div>

    <div class="services-grid">
      {services.map((s) => (
        <a href={s.href} class="service-card reveal">
          <div class="s-num">{s.num}</div>
          <div class="s-icon" set:html={s.icon} />
          <h3 class="s-title">{s.title}</h3>
          <p class="s-desc">{s.desc}</p>
          <div class="s-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
      ))}
    </div>

    <div class="services-cta">
      <a href="/services" class="btn-outline">
        Explore All Services
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>

<style>
  .services-section { background: #111111; }

  .services-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .services-header h2 { color: #fff; margin-bottom: 1rem; }
  .services-sub {
    max-width: 560px;
    margin: 0 auto;
    font-size: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2px;
    margin-bottom: 3rem;
  }

  .service-card {
    position: relative;
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 2.25rem 2rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    overflow: hidden;
    display: flex; flex-direction: column; gap: 0.6rem;
  }
  .service-card::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 100%; height: 2px;
    background: linear-gradient(90deg, #CC1417, #E8601A);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .service-card::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(204,20,23,0.04) 0%, transparent 60%);
    opacity: 0; transition: opacity 0.3s ease;
  }
  .service-card:hover {
    border-color: rgba(232,96,26,0.25);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(204,20,23,0.08);
  }
  .service-card:hover::before { transform: scaleX(1); }
  .service-card:hover::after  { opacity: 1; }

  .s-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.72rem; font-weight: 800;
    color: #CC1417; letter-spacing: 0.1em; opacity: 0.7;
  }
  .s-icon { color: #CC1417; margin-bottom: 2px; }
  .s-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.15rem; font-weight: 800;
    color: #ffffff; text-transform: uppercase;
    letter-spacing: 0.03em; line-height: 1.2;
  }
  .s-desc {
    font-size: 0.86rem; color: rgba(255,255,255,0.5);
    line-height: 1.7; flex: 1;
  }
  .s-arrow {
    color: #E8601A; opacity: 0;
    transform: translateX(-6px);
    transition: all 0.3s ease;
    align-self: flex-end; margin-top: 4px;
  }
  .service-card:hover .s-arrow { opacity: 1; transform: translateX(0); }

  .services-cta { text-align: center; }

  @media (max-width: 768px) {
    .services-grid { grid-template-columns: 1fr; }
  }
</style>
