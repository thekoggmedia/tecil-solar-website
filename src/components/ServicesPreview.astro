---
import { services } from '../data/site';
const colorMap: Record<string,string> = { installation:'red', maintenance:'orange', assessment:'teal', supply:'gold', projects:'red', training:'teal' };
---
<section class="section bg-off sv">
  <div class="container">
    <div class="sv-head reveal">
      <div>
        <span class="section-tag">What We Do</span>
        <h2>End-to-End <span class="text-gradient">Solar Services</span></h2>
        <p class="sv-sub">From a single home system to a 60KW off-grid industrial project — we handle everything: supply, design, install, maintain, train.</p>
      </div>
      <a href="/services" class="btn-outline" style="flex-shrink:0">
        All Services
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="sv-grid">
      {services.map((s,i)=>(
        <a href={`/services#${s.id}`} class={`sv-card sc-${colorMap[s.id]||'red'} reveal reveal-delay-${i%4}`}>
          <div class="sc-top">
            <span class="sc-num">0{i+1}</span>
            <span class={`sc-chip chip-${colorMap[s.id]||'red'}`}>{s.eyebrow}</span>
          </div>
          <h3 class="sc-title">{s.title}</h3>
          <p class="sc-desc">{s.summary}</p>
          <span class="sc-link">
            View details
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
<style>
.sv-head { display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2.5rem;flex-wrap:wrap;gap:1.5rem; }
.sv-head h2 { color:#111827;margin-bottom:.5rem; }
.sv-sub { color:#6B7280;max-width:48ch; }
.sv-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1.5px; }

.sv-card { background:#fff;border:1px solid #E5E7EB;padding:2rem 1.75rem;text-decoration:none;transition:all .3s ease;display:flex;flex-direction:column;gap:.6rem;position:relative;overflow:hidden; }
.sv-card::before { content:'';position:absolute;top:0;left:0;right:0;height:3px;transform:scaleX(0);transform-origin:left;transition:transform .3s ease; }
.sc-red::before   { background:linear-gradient(90deg,#CC1417,#E8601A); }
.sc-orange::before{ background:linear-gradient(90deg,#E8601A,#f09050); }
.sc-teal::before  { background:linear-gradient(90deg,#006D77,#0099a8); }
.sc-gold::before  { background:linear-gradient(90deg,#C8960C,#e0b020); }
.sv-card:hover { transform:translateY(-5px);box-shadow:0 16px 40px rgba(0,0,0,.09);border-color:transparent; }
.sv-card:hover::before { transform:scaleX(1); }

.sc-top { display:flex;justify-content:space-between;align-items:center; }
.sc-num { font-family:'Nunito Sans',sans-serif;font-size:2.4rem;color:rgba(204,20,23,.12);line-height:1;font-variation-settings:'wdth' 125,'wght' 900; }
.sc-chip { font-size:.65rem;font-weight:700;padding:3px 10px;border-radius:999px;text-transform:uppercase;letter-spacing:.06em;font-variation-settings:'wdth' 100,'wght' 700; }
.chip-red   { background:#FFF1F1;color:#CC1417; }
.chip-orange{ background:#FFF5EE;color:#E8601A; }
.chip-teal  { background:#EDF7F8;color:#006D77; }
.chip-gold  { background:#FFFBEA;color:#C8960C; }

.sc-title { font-family:'Nunito Sans',sans-serif;font-size:1.08rem;font-weight:800;color:#111827;line-height:1.2;text-transform:uppercase;letter-spacing:.02em;font-variation-settings:'wdth' 125,'wght' 800; }
.sc-desc  { font-size:.86rem;color:#6B7280;line-height:1.7;flex:1; }
.sc-link  { display:inline-flex;align-items:center;gap:5px;font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#CC1417;margin-top:4px;transition:gap .2s;font-variation-settings:'wdth' 100,'wght' 700; }
.sv-card:hover .sc-link { gap:9px; }

@media(max-width:900px){ .sv-grid{grid-template-columns:1fr 1fr} }
@media(max-width:600px){ .sv-grid{grid-template-columns:1fr} .sv-head{flex-direction:column} }
</style>
