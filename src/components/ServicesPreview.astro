---
import { services } from '../data/site';
---

<section class="section bg-off services-preview">
  <div class="container">
    <div class="section-head reveal">
      <div>
        <span class="section-tag">Services</span>
        <h2>Designed to answer the client’s brief clearly.</h2>
      </div>
      <p>
        Every service is now presented as a real business offering, not a vague paragraph. That gives the site stronger sales intent.
      </p>
    </div>

    <div class="service-grid">
      {services.map((item, index) => (
        <article class:list={['service-card', 'reveal', `reveal-delay-${(index % 5) + 1}`]}>
          <div class="service-top">
            <span class="service-no">{item.id.slice(-2)}</span>
            <span class="service-chip">{item.eyebrow}</span>
          </div>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <ul>
            {item.bullets.map((bullet) => <li>{bullet}</li>)}
          </ul>
          <a href={`/services#${item.id}`} class="service-link">View details</a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .section-head {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: end;
    margin-bottom: 2rem;
  }

  .section-head h2 {
    max-width: 11ch;
  }

  .section-head p {
    max-width: 54ch;
    font-size: 1.02rem;
  }

  .service-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.15rem;
  }

  .service-card {
    padding: 1.35rem;
    border-radius: 28px;
    background: #fff;
    border: 1px solid var(--border);
    box-shadow: 0 14px 38px rgba(15,23,42,0.05);
  }

  .service-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .service-no {
    font-family: var(--font-display);
    font-size: 2.4rem;
    line-height: 1;
    color: rgba(204,20,23,0.16);
  }

  .service-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    background: rgba(232,96,26,0.10);
    color: var(--orange);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .service-card h3 {
    font-size: 1.55rem;
  }

  .service-card p {
    margin-top: 0.7rem;
  }

  .service-card ul {
    margin: 1rem 0 1.2rem;
    padding-left: 1.1rem;
    color: var(--muted);
  }

  .service-card li + li {
    margin-top: 0.42rem;
  }

  .service-link {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
  }

  @media (max-width: 1020px) {
    .service-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .section-head {
      flex-direction: column;
      align-items: start;
    }

    .service-grid {
      grid-template-columns: 1fr;
    }
  }
</style>