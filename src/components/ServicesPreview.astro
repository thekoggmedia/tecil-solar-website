---
const services = [
  { num:"01", title:"Professional Installation", desc:"End-to-end installation of solar, inverter backup, and hybrid systems. Every job documented with a signed commissioning report.", icon:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`, href:"/services#installation", color:"red" },
  { num:"02", title:"Maintenance & Repair", desc:"Scheduled preventive maintenance and reactive repair for all solar and inverter systems. SLAs available for commercial clients.", icon:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`, href:"/services#maintenance", color:"orange" },
  { num:"03", title:"Load Assessment", desc:"Pre-installation energy audits and load assessments to right-size your system. Includes ROI and payback period analysis.", icon:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`, href:"/services#assessment", color:"teal" },
  { num:"04", title:"Technical Training", desc:"Solar and inverter design, installation, and maintenance courses for technicians, contractors, and entrepreneurs.", icon:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`, href:"/services#training", color:"gold" },
  { num:"05", title:"Large-Scale EPC Projects", desc:"Full Engineering, Procurement and Construction for government, institutional, and industrial clients. Fully documented delivery.", icon:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`, href:"/services#projects", color:"red" },
  { num:"06", title:"Energy-as-a-Service", desc:"Access solar power without upfront capital. Monthly service fee model in partnership with financing institutions. 2026–2028 rollout.", icon:`<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`, href:"/services#eaas", color:"teal" },
];
---
<section class="sv section">
  <div class="container">
    <div class="sv-head">
      <div>
        <span class="section-tag">What We Do</span>
        <h2>End-to-End <span class="text-gradient">Solar Services</span></h2>
        <p class="sv-sub">From a single home system to a 60KW off-grid industrial project — we handle everything.</p>
      </div>
      <a href="/services" class="btn-outline">
        All Services
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="sv-grid">
      {services.map((s,i)=>(
        <a href={s.href} class={`sv-card sc-${s.color} reveal reveal-delay-${i%3}`}>
          <div class="sc-top">
            <div class={`sc-icon si-${s.color}`} set:html={s.icon}/>
            <span class="sc-num">{s.num}</span>
          </div>
          <h3 class="sc-title">{s.title}</h3>
          <p class="sc-desc">{s.desc}</p>
          <span class="sc-arrow">
            Learn more
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.sv { background:#F7F8FA; }

.sv-head {
  display:flex; justify-content:space-between; align-items:flex-end;
  margin-bottom:3rem; flex-wrap:wrap; gap:1.5rem;
}
.sv-head h2 { color:#111827; margin-bottom:.5rem; }
.sv-sub { color:#6B7280; max-width:460px; }

.sv-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:1.5px;
}

.sv-card {
  background:#fff; border:1px solid #E5E7EB;
  padding:2rem 1.75rem;
  text-decoration:none; transition:all .3s ease;
  display:flex; flex-direction:column; gap:.6rem;
  position:relative; overflow:hidden;
}
.sv-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  transform:scaleX(0); transform-origin:left; transition:transform .3s ease;
}
.sc-red::before   { background:linear-gradient(90deg,#CC1417,#E8601A); }
.sc-orange::before{ background:linear-gradient(90deg,#E8601A,#f0874a); }
.sc-teal::before  { background:linear-gradient(90deg,#006D77,#00969f); }
.sc-gold::before  { background:linear-gradient(90deg,#C8960C,#e0ad1a); }

.sv-card:hover { transform:translateY(-5px); box-shadow:0 16px 40px rgba(0,0,0,.10); border-color:transparent; }
.sv-card:hover::before { transform:scaleX(1); }

.sc-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:.25rem; }
.sc-icon { width:48px;height:48px; border-radius:8px; display:flex;align-items:center;justify-content:center; }
.si-red   { background:#FFF1F1; color:#CC1417; }
.si-orange{ background:#FFF5EE; color:#E8601A; }
.si-teal  { background:#EDF7F8; color:#006D77; }
.si-gold  { background:#FFFBEA; color:#C8960C; }

.sc-num { font-family:'Big Shoulders Display',sans-serif; font-size:3rem; font-weight:900; color:#F3F4F6; line-height:1; }

.sc-title { font-family:'Big Shoulders Display',sans-serif; font-size:1.2rem; font-weight:800; text-transform:uppercase; color:#111827; line-height:1.15; letter-spacing:.02em; }
.sc-desc  { font-size:.85rem; color:#6B7280; line-height:1.7; flex:1; }
.sc-arrow {
  display:inline-flex; align-items:center; gap:5px;
  font-family:'DM Sans',sans-serif; font-size:.76rem; font-weight:700;
  text-transform:uppercase; letter-spacing:.06em; color:#CC1417;
  margin-top:4px; transition:gap .2s;
}
.sv-card:hover .sc-arrow { gap:9px; }

@media(max-width:900px){ .sv-grid{ grid-template-columns:1fr 1fr; } }
@media(max-width:600px){ .sv-grid{ grid-template-columns:1fr; } .sv-head{ flex-direction:column; } }
</style>
