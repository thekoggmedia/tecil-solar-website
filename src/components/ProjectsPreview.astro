---
import { projects } from '../data/site';
---

<section class="section bg-dark projects-preview">
  <div class="container project-shell">
    <div class="project-copy reveal">
      <span class="section-tag">Selected Work</span>
      <h2>One contrast break keeps the page interesting.</h2>
      <p class="project-lead">
        A dark section here makes the flow feel premium and gives the portfolio more visual importance.
      </p>

      <div class="project-metrics">
        <div><strong>34+</strong><span>Projects</span></div>
        <div><strong>7</strong><span>Locations</span></div>
        <div><strong>18+</strong><span>Years</span></div>
      </div>

      <a href="/projects" class="btn-outline-white">View Case Studies</a>
    </div>

    <div class="project-grid">
      {projects.map((item, index) => (
        <article class:list={['project-card', 'reveal', `reveal-delay-${index + 1}`]}>
          <div class="project-top">
            <span>{item.tag}</span>
            <strong>{item.location}</strong>
          </div>
          <h3>{item.title}</h3>
          <p>{item.summary}</p>
          <div class="project-result">{item.result}</div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-preview {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(circle at top right, rgba(204,20,23,0.20), transparent 25%),
      radial-gradient(circle at bottom left, rgba(232,96,26,0.12), transparent 22%),
      #0F1117;
  }

  .project-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: 2rem;
    align-items: start;
  }

  .project-copy h2 {
    color: #fff;
    max-width: 10ch;
    margin-top: 0.6rem;
  }

  .project-lead {
    margin-top: 1rem;
    color: rgba(255,255,255,0.68);
    max-width: 48ch;
  }

  .project-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin: 1.4rem 0 1.55rem;
  }

  .project-metrics div {
    padding: 1rem;
    border-radius: 22px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.05);
  }

  .project-metrics strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2.25rem;
    color: #fff;
    line-height: 1;
  }

  .project-metrics span {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.44);
  }

  .project-grid {
    display: grid;
    gap: 1rem;
  }

  .project-card {
    padding: 1.35rem;
    border-radius: 28px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(12px);
    box-shadow: 0 22px 54px rgba(0,0,0,0.20);
  }

  .project-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.54);
  }

  .project-card h3 {
    color: #fff;
    font-size: 1.7rem;
  }

  .project-card p {
    margin-top: 0.65rem;
    color: rgba(255,255,255,0.68);
  }

  .project-result {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    color: #FFBE8A;
    font-size: 0.92rem;
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .project-shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .project-metrics {
      grid-template-columns: 1fr;
    }
  }
</style>