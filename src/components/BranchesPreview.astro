---
import { branches } from '../data/site';

const previewBranches = branches.slice(0, 5);
---

<section class="section bg-teal branches-preview">
  <div class="container">
    <div class="section-head reveal">
      <div>
        <span class="section-tag">Operating Across Nigeria</span>
        <h2>Equal presence. No over-emphasis on one city.</h2>
      </div>
      <p>
        The branch story is now balanced: strong presence in the locations you operate in, without making one location feel bigger than the others.
      </p>
    </div>

    <div class="branch-grid">
      {previewBranches.map((item, index) => (
        <article class:list={['branch-card', 'reveal', `reveal-delay-${(index % 5) + 1}`]}>
          <span class="branch-city">{item.city}</span>
          <strong>{item.state}</strong>
          <p>{item.address}</p>
        </article>
      ))}
    </div>

    <div class="branch-bar reveal reveal-delay-3">
      <span>Lagos</span>
      <span>Port Harcourt</span>
      <span>Calabar</span>
      <span>Uyo</span>
      <span>Ikom</span>
    </div>
  </div>
</section>

<style>
  .branch-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  .branch-card {
    padding: 1.2rem 1.15rem;
    border-radius: 24px;
    border: 1px solid rgba(6,109,119,0.16);
    background: rgba(255,255,255,0.86);
    box-shadow: 0 14px 34px rgba(15,23,42,0.05);
  }

  .branch-city {
    display: inline-flex;
    margin-bottom: 0.65rem;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--teal);
  }

  .branch-card strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.45rem;
    line-height: 1;
    color: var(--text);
  }

  .branch-card p {
    margin-top: 0.7rem;
    font-size: 0.92rem;
  }

  .branch-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 1rem;
  }

  .branch-bar span {
    display: inline-flex;
    align-items: center;
    padding: 0.7rem 0.92rem;
    border-radius: 999px;
    background: rgba(255,255,255,0.75);
    border: 1px solid rgba(6,109,119,0.12);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
  }

  @media (max-width: 1120px) {
    .branch-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 720px) {
    .branch-grid {
      grid-template-columns: 1fr;
    }
  }
</style>