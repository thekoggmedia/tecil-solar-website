---
import { branches } from '../data/site';
const featured = branches.slice(0,5);
---
<section class="section bg-teal br">
  <div class="container">
    <div class="br-head reveal">
      <div>
        <span class="section-tag">Find Us</span>
        <h2>Operating <span class="text-gradient">Across Nigeria</span></h2>
        <p class="br-sub">7 branches across 5 states. Walk into any TECIL Solar location and receive the same expertise, product quality, and service standard.</p>
      </div>
      <a href="/branches" class="btn-outline" style="flex-shrink:0">
        All Locations
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
    <div class="br-grid">
      {featured.map((b,i)=>(
        <div class={`br-card reveal reveal-delay-${i}`}>
          {b.hq && <span class="br-hq">HQ</span>}
          <div class="brc-state">{b.state}</div>
          <div class="brc-city">{b.city}</div>
          <div class="brc-address">{b.address}</div>
          <div class="brc-contacts">
            <a href={b.telHref} class="brc-tel">{b.phone}</a>
            <a href={b.waHref} target="_blank" class="brc-wa">WhatsApp</a>
          </div>
        </div>
      ))}
      <div class="br-card br-more reveal reveal-delay-4">
        <div>📍</div>
        <strong>+2 More Branches</strong>
        <a href="/branches">View All →</a>
      </div>
    </div>
    <div class="br-reach reveal">
      <div class="brr">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#006D77" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>Lagos · Port Harcourt · Calabar · Uyo · Ikom and growing</span>
      </div>
      <div class="brr">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#006D77" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.38a2 2 0 0 1 1.99-1.8h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17z"/></svg>
        <span>Call <strong>0803 713 5545</strong> or <a href="https://wa.me/2348037135545" target="_blank">WhatsApp us</a> from anywhere in Nigeria</span>
      </div>
    </div>
  </div>
</section>
<style>
.br-head { display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2.5rem;flex-wrap:wrap;gap:1.5rem; }
.br-head h2 { color:#111827;margin-bottom:.75rem; }
.br-sub { color:#4B5563;max-width:50ch; }
.br-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:1.5px;margin-bottom:1rem; }
.br-card { background:#fff;border:1px solid #D1FAE5;padding:1.75rem 1.5rem;position:relative;transition:all .3s ease;display:flex;flex-direction:column;gap:6px; }
.br-card::before { content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,#006D77,#0099a8);transform:scaleX(0);transform-origin:left;transition:transform .3s ease; }
.br-card:hover { box-shadow:0 8px 28px rgba(0,109,119,.12);transform:translateY(-3px);border-color:rgba(0,109,119,.2); }
.br-card:hover::before { transform:scaleX(1); }
.br-hq { position:absolute;top:10px;right:12px;background:#CC1417;color:#fff;font-size:.55rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 7px;border-radius:4px; }
.brc-state { font-size:.62rem;font-weight:700;color:#006D77;letter-spacing:.1em;text-transform:uppercase;font-variation-settings:'wdth' 100,'wght' 700; }
.brc-city  { font-family:'Nunito Sans',sans-serif;font-size:1.1rem;font-weight:800;text-transform:uppercase;color:#111827;font-variation-settings:'wdth' 125,'wght' 800; }
.brc-address { font-size:.78rem;color:#6B7280;line-height:1.5; }
.brc-contacts { display:flex;gap:8px;flex-wrap:wrap;margin-top:4px; }
.brc-tel,.brc-wa { font-size:.76rem;font-weight:600;text-decoration:none;padding:4px 10px;border-radius:4px;transition:all .2s;font-variation-settings:'wdth' 100,'wght' 600; }
.brc-tel { color:#E8601A;background:#FFF5EE;border:1px solid rgba(232,96,26,.2); }
.brc-tel:hover { background:#E8601A;color:#fff; }
.brc-wa  { color:#166534;background:rgba(37,211,102,.08);border:1px solid rgba(37,211,102,.2); }
.brc-wa:hover { background:#25D366;color:#fff;border-color:#25D366; }
.br-more { align-items:center;justify-content:center;text-align:center;background:#F0FDF4 !important;border-color:rgba(0,109,119,.15) !important; }
.br-more div { font-size:1.5rem; }
.br-more strong { font-family:'Nunito Sans',sans-serif;font-size:.92rem;color:#4B5563;font-variation-settings:'wdth' 100,'wght' 700; }
.br-more a { font-size:.78rem;font-weight:700;color:#006D77;text-decoration:none;text-transform:uppercase;letter-spacing:.06em; }
.br-reach { display:flex;flex-wrap:wrap;gap:1.5rem;background:#fff;border:1px solid #E5E7EB;padding:1.1rem 1.75rem;border-radius:6px; }
.brr { display:flex;align-items:center;gap:8px;font-size:.86rem;color:#4B5563; }
.brr strong { color:#111827; }
.brr a { color:#006D77;font-weight:600; }
.brr a:hover { color:#CC1417; }
@media(max-width:900px){ .br-grid{grid-template-columns:1fr 1fr} }
@media(max-width:600px){ .br-grid{grid-template-columns:1fr} .br-head{flex-direction:column} }
</style>
