---
const branches = [
  { name:"Lagos", state:"Lagos State", tel:"0802 683 5985" },
  { name:"Port Harcourt", state:"Rivers State", tel:"0701 616 4397" },
  { name:"Calabar", state:"Cross River State", tel:"0803 713 5545", hq:true },
  { name:"Uyo", state:"Akwa Ibom State", tel:"0812 113 8060" },
  { name:"Ikom", state:"Cross River State", tel:"0803 560 1371" },
];
---
<section class="br section">
  <div class="container">
    <div class="br-head reveal">
      <div>
        <span class="section-tag">Find Us</span>
        <h2>Operating <span class="text-gradient">Across Nigeria</span></h2>
        <p class="br-sub">7 branches across 5 states — walk into any TECIL Solar location and receive the same level of expertise, product quality, and service.</p>
      </div>
      <a href="/branches" class="btn-outline">
        All Locations
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <div class="br-grid">
      {branches.map((b,i)=>(
        <div class={`br-card reveal reveal-delay-${i}`}>
          {b.hq && <span class="br-hq-badge">HQ</span>}
          <div class="brc-state">{b.state}</div>
          <div class="brc-name">{b.name}</div>
          <a href={`tel:+234${b.tel.replace(/\s/g,'').slice(1)}`} class="brc-tel">{b.tel}</a>
        </div>
      ))}
      <div class="br-card br-more reveal reveal-delay-4">
        <div class="bm-icon">📍</div>
        <div class="bm-text">+ 2 more branches</div>
        <a href="/branches" class="bm-link">View All →</a>
      </div>
    </div>

    <div class="br-reach reveal">
      <div class="brr-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#006D77" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span>Lagos · Port Harcourt · Calabar · Uyo · Ikom</span>
      </div>
      <div class="brr-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#006D77" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.38a2 2 0 0 1 1.99-1.8h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17z"/></svg>
        <span>Call <strong>0803 713 5545</strong> for nearest branch</span>
      </div>
      <div class="brr-item">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        <a href="https://wa.me/2348037135545" target="_blank">WhatsApp us directly</a>
      </div>
    </div>
  </div>
</section>

<style>
.br { background:#EDF7F8; }

.br-head { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:3rem; flex-wrap:wrap; gap:1.5rem; }
.br-head h2 { color:#111827; margin-bottom:.75rem; }
.br-sub { color:#4B5563; max-width:500px; }

.br-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1.5px; margin-bottom:2rem; }

.br-card {
  background:#fff; border:1px solid #E5E7EB; padding:1.75rem 1.5rem;
  position:relative; transition:all .3s ease;
}
.br-card::before {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg,#006D77,#00969f);
  transform:scaleX(0); transform-origin:left; transition:transform .3s ease;
}
.br-card:hover { box-shadow:0 8px 28px rgba(0,109,119,.12); transform:translateY(-3px); border-color:rgba(0,109,119,.2); }
.br-card:hover::before { transform:scaleX(1); }

.br-hq-badge { position:absolute; top:10px; right:12px; background:#CC1417; color:#fff; font-size:.55rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; padding:3px 7px; border-radius:3px; }
.brc-state { font-family:'DM Sans',sans-serif; font-size:.62rem; font-weight:700; color:#006D77; letter-spacing:.1em; text-transform:uppercase; margin-bottom:5px; }
.brc-name { font-family:'Big Shoulders Display',sans-serif; font-size:1.3rem; font-weight:900; text-transform:uppercase; color:#111827; margin-bottom:10px; }
.brc-tel { font-family:'DM Sans',sans-serif; font-size:.84rem; font-weight:600; color:#E8601A; text-decoration:none; transition:color .2s; }
.brc-tel:hover { color:#CC1417; }

.br-more {
  background:#F0FDF9 !important; border-color:rgba(0,109,119,.2) !important;
  display:flex !important; flex-direction:column; align-items:center; justify-content:center;
  text-align:center; gap:8px;
}
.bm-icon { font-size:1.6rem; }
.bm-text { font-family:'DM Sans',sans-serif; font-size:.84rem; font-weight:600; color:#4B5563; }
.bm-link { font-family:'DM Sans',sans-serif; font-size:.76rem; font-weight:700; color:#006D77; text-decoration:none; text-transform:uppercase; letter-spacing:.06em; }

.br-reach {
  display:flex; flex-wrap:wrap; gap:2rem;
  background:#fff; border:1px solid #E5E7EB;
  padding:1.25rem 2rem; border-radius:4px;
}
.brr-item { display:flex; align-items:center; gap:8px; font-family:'DM Sans',sans-serif; font-size:.88rem; color:#4B5563; }
.brr-item strong { color:#111827; }
.brr-item a { color:#006D77; font-weight:600; text-decoration:none; }
.brr-item a:hover { color:#CC1417; }

@media(max-width:900px){ .br-grid{grid-template-columns:1fr 1fr;} }
@media(max-width:600px){ .br-grid{grid-template-columns:1fr;} .br-head{flex-direction:column;} }
</style>
