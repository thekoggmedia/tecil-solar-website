---
interface Props { variant?: 'light' | 'dark' }
const { variant = 'light' } = Astro.props;

// Each brand has a slug that maps to a file in /public/brands/
// Accepted formats: SVG (preferred) or PNG
// Drop your logo files into public/brands/ using the exact slugs below
const brands = [
  { name: 'Jinko Solar',    tag: 'Panels',           slug: 'jinko-solar' },
  { name: 'Longi Solar',    tag: 'Panels',           slug: 'longi-solar' },
  { name: 'Felicity Solar', tag: 'Panels & Systems', slug: 'felicity-solar' },
  { name: 'Deye',           tag: 'Hybrid Inverters', slug: 'deye' },
  { name: 'Smarten',        tag: 'Inverters',        slug: 'smarten' },
  { name: 'Dique',          tag: 'Inverters',        slug: 'dique' },
  { name: 'Tsolar',         tag: 'Systems',          slug: 'tsolar' },
  { name: 'Restar',         tag: 'Batteries',        slug: 'restar' },
  { name: 'EcoFlow',        tag: 'Portable Power',   slug: 'ecoflow' },
  { name: 'Oraimo',         tag: 'Solar Accessories',slug: 'oraimo' },
  { name: 'itel',           tag: 'Energy Products',  slug: 'itel' },
];
---

<section class={`brands-strip bs-${variant}`}>
  <div class="container">
    <div class="bs-head reveal">
      <div>
        <span class="section-tag" style={variant==='dark' ? 'color:#E8601A' : ''}>Authorised Partners</span>
        <p class={`bs-note ${variant==='dark' ? 'bs-note-dark' : ''}`}>
          TECIL Solar is an authorised distributor and partner for 15+ world-class international brands
        </p>
      </div>
      <a href="/products" class={`bs-cta ${variant==='dark' ? 'bs-cta-dark' : ''}`}>
        Browse Products
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Scrolling marquee -->
  <div class="bs-marquee" aria-hidden="true">
    <div class="bs-track">
      {[...brands, ...brands, ...brands].map(b => (
        <div class={`bs-chip bc-${variant}`}>
          <div class="bc-logo-wrap">
            <!-- SVG tried first, PNG as fallback, brand initial as last resort -->
            <img
              class="bc-logo"
              src={`/brands/${b.slug}.svg`}
              alt={b.name}
              onerror={`this.onerror=null;this.src='/brands/${b.slug}.png';this.onerror=function(){this.style.display='none';this.nextElementSibling.style.display='flex'}`}
            />
            <span class="bc-logo-fallback">{b.name.charAt(0)}</span>
          </div>
          <span class="bc-name">{b.name}</span>
          <span class="bc-tag">{b.tag}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- Static grid -->
  <div class="container">
    <div class="bs-grid">
      {brands.map((b, i) => (
        <div class={`bs-item bi-${variant} reveal reveal-delay-${(i % 5) + 1}`}>
          <div class="bi-logo-wrap">
            <img
              class="bi-logo"
              src={`/brands/${b.slug}.svg`}
              alt={b.name}
              onerror={`this.onerror=null;this.src='/brands/${b.slug}.png';this.onerror=function(){this.style.display='none';this.nextElementSibling.style.display='flex'}`}
            />
            <!-- Fallback: brand initial in coloured circle -->
            <div class={`bi-logo-fallback bif-${variant}`}>
              <span>{b.name.charAt(0)}</span>
            </div>
          </div>
          <div class="bi-text">
            <strong>{b.name}</strong>
            <span>{b.tag}</span>
          </div>
        </div>
      ))}
      <div class={`bs-item bi-${variant} bi-more reveal`}>
        <div class="bi-logo-wrap">
          <div class={`bi-logo-fallback bif-${variant}`} style="display:flex">
            <span>+</span>
          </div>
        </div>
        <div class="bi-text">
          <strong>More Brands</strong>
          <span>Growing portfolio</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.brands-strip { padding:4rem 0; overflow:hidden; }
.bs-light { background:var(--off); border-top:1px solid var(--border); border-bottom:1px solid var(--border); }
.bs-dark  { background:var(--dark-2); border-top:1px solid rgba(255,255,255,.06); border-bottom:1px solid rgba(255,255,255,.06); }

.bs-head { display:flex; align-items:center; justify-content:space-between; gap:1.5rem; margin-bottom:1.5rem; flex-wrap:wrap; }
.bs-note { font-size:.86rem; color:var(--muted); max-width:48ch; margin-top:4px; }
.bs-note-dark { color:rgba(255,255,255,.45); }

.bs-cta {
  display:inline-flex; align-items:center; gap:6px;
  font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em;
  color:#CC1417; border:1.5px solid rgba(204,20,23,.25); border-radius:6px;
  padding:.45rem .9rem; text-decoration:none; white-space:nowrap;
  transition:all .2s ease; flex-shrink:0;
  font-variation-settings:'wdth' 100,'wght' 700;
}
.bs-cta:hover { background:#CC1417; color:#fff; border-color:#CC1417; }
.bs-cta-dark { color:#E8601A; border-color:rgba(232,96,26,.3); }
.bs-cta-dark:hover { background:#E8601A; color:#fff; border-color:#E8601A; }

/* MARQUEE */
.bs-marquee { overflow:hidden; margin-bottom:2rem; }
.bs-track {
  display:flex; width:max-content;
  animation:brandScroll 40s linear infinite;
  gap:8px; padding:4px 0;
}
.bs-track:hover { animation-play-state:paused; }

.bs-chip {
  display:inline-flex; align-items:center; gap:8px;
  padding:.5rem 1rem; border-radius:8px;
  flex-shrink:0; white-space:nowrap; cursor:default;
  transition:all .2s ease;
}
.bc-light { background:#fff; border:1.5px solid var(--border); box-shadow:0 1px 4px rgba(0,0,0,.05); }
.bc-dark  { background:rgba(255,255,255,.05); border:1.5px solid rgba(255,255,255,.10); }
.bc-light:hover { border-color:rgba(204,20,23,.35); transform:translateY(-2px); }
.bc-dark:hover  { border-color:rgba(232,96,26,.4);  transform:translateY(-2px); background:rgba(255,255,255,.08); }

/* MARQUEE LOGO */
.bc-logo-wrap {
  width:28px; height:28px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
}
.bc-logo {
  max-width:28px; max-height:28px; object-fit:contain; display:block;
}
.bc-logo-fallback {
  display:none; width:28px; height:28px; border-radius:6px;
  align-items:center; justify-content:center;
  background:linear-gradient(135deg,#CC1417,#E8601A);
  color:#fff; font-size:.75rem; font-weight:900;
  font-variation-settings:'wdth' 125,'wght' 900;
}

.bc-name { font-size:.82rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; font-variation-settings:'wdth' 100,'wght' 700; }
.bc-light .bc-name { color:var(--text); }
.bc-dark  .bc-name { color:rgba(255,255,255,.9); }
.bc-tag { font-size:.62rem; font-weight:500; padding:2px 7px; border-radius:4px; font-variation-settings:'wdth' 100,'wght' 500; }
.bc-light .bc-tag { background:var(--orange-light); color:var(--orange); }
.bc-dark  .bc-tag { background:rgba(232,96,26,.15); color:#E8601A; }

/* STATIC GRID */
.bs-grid { display:grid; grid-template-columns:repeat(6,1fr); gap:8px; margin-top:.5rem; }

.bs-item {
  display:flex; align-items:center; gap:10px;
  padding:.9rem 1rem; border-radius:10px;
  border:1.5px solid; cursor:default;
  transition:all .25s ease;
}
.bi-light { background:#fff; border-color:var(--border); }
.bi-dark  { background:rgba(255,255,255,.04); border-color:rgba(255,255,255,.08); }
.bi-light:hover { border-color:rgba(204,20,23,.3); transform:translateY(-2px); box-shadow:0 4px 14px rgba(0,0,0,.07); }
.bi-dark:hover  { border-color:rgba(204,20,23,.3); background:rgba(204,20,23,.06); transform:translateY(-2px); }

/* GRID LOGO */
.bi-logo-wrap {
  width:36px; height:36px; flex-shrink:0;
  display:flex; align-items:center; justify-content:center;
}
.bi-logo { max-width:36px; max-height:36px; object-fit:contain; display:block; }
.bi-logo-fallback {
  display:none; width:36px; height:36px; border-radius:8px;
  align-items:center; justify-content:center;
  font-size:.85rem; font-weight:900;
  font-variation-settings:'wdth' 125,'wght' 900;
}
.bif-light { background:var(--red-light); color:var(--red); }
.bif-dark  { background:rgba(204,20,23,.15); color:#E8601A; }

.bi-text { display:flex; flex-direction:column; gap:1px; min-width:0; }
.bi-text strong { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; font-variation-settings:'wdth' 100,'wght' 700; }
.bi-text span   { font-size:.6rem; font-weight:500; font-variation-settings:'wdth' 100,'wght' 500; }
.bi-light strong { color:var(--text); }
.bi-dark  strong { color:rgba(255,255,255,.9); }
.bi-light span   { color:var(--soft); }
.bi-dark  span   { color:rgba(255,255,255,.38); }

@keyframes brandScroll { 0%{ transform:translateX(0) } 100%{ transform:translateX(-33.333%) } }
@media(max-width:1080px){ .bs-grid{ grid-template-columns:repeat(4,1fr); } }
@media(max-width:700px){  .bs-grid{ grid-template-columns:repeat(2,1fr); } }
</style>