---
import { audiences } from '../data/site';
---

<section class="section bg-white audience-section">
  <div class="container">
    <div class="section-head reveal">
      <div>
        <span class="section-tag">Who We Serve</span>
        <h2>Clearer audience targeting makes the site feel stronger.</h2>
      </div>
      <p>
        This section helps visitors quickly find themselves in the story and understand whether Tecil Solar is the right fit.
      </p>
    </div>

    <div class="audience-grid">
      {audiences.map((item, index) => (
        <article class:list={['audience-card', 'reveal', `reveal-delay-${(index % 5) + 1}`]}>
          <span class="audience-kicker">0{index + 1}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <ul>
            {item.points.map((point) => <li>{point}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .audience-card {
    padding: 1.45rem;
    border-radius: 28px;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, #fff, #fcfcfd);
    box-shadow: 0 12px 30px rgba(15,23,42,0.05);
    position: relative;
    overflow: hidden;
  }

  .audience-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 4px;
    background: linear-gradient(90deg, var(--red), var(--orange));
  }

  .audience-card:nth-child(2)::before {
    background: linear-gradient(90deg, var(--orange), #C8960C);
  }

  .audience-card:nth-child(3)::before {
    background: linear-gradient(90deg, var(--teal), #6AC6D1);
  }

  .audience-card:nth-child(4)::before {
    background: linear-gradient(90deg, #0F1117, #394150);
  }

  .audience-kicker {
    display: inline-flex;
    align-items: center;
    margin-bottom: 1rem;
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
    color: rgba(15,17,23,0.12);
  }

  .audience-card h3 {
    font-size: 1.5rem;
  }

  .audience-card p {
    margin-top: 0.65rem;
  }

  .audience-card ul {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
    color: var(--muted);
  }

  .audience-card li + li {
    margin-top: 0.42rem;
  }

  @media (max-width: 1020px) {
    .audience-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .audience-grid {
      grid-template-columns: 1fr;
    }
  }
</style>