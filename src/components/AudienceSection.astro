---
import { audiences } from '../data/site';
---

<section class="section bg-white au">
  <div class="container">
    <div class="au-head reveal">
      <span class="section-tag">Who We Serve</span>
      <h2>One Company. <span class="text-gradient">Every Energy Need.</span></h2>
      <p class="au-sub">
        Whether you're a homeowner, an SME, a government institution, or a developer —
        TECIL Solar has been solving your energy problem since 2008.
      </p>
    </div>

    <div class="au-grid">
      {audiences.map((a,i)=>(
        <div class={`au-card ac-${a.color} reveal reveal-delay-${i}`}>
          
          <div class="ac-top">
            <span class="ac-icon">{a.icon}</span>
            <span class={`ac-label al-${a.color}`}>{a.title}</span>
          </div>

          {/* ✅ CLEAN TITLE (NO MORE SPLIT HACK) */}
          <h3 class="ac-title">{a.intro}</h3>

          {/* ✅ SUPPORTING TEXT */}
          <p class="ac-body">{a.body}</p>

          <ul class="ac-points">
            {a.points.map(p=><li>{p}</li>)}
          </ul>

          <a href="/contact" class={`ac-link al-${a.color}`}>
            Talk to us
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>

        </div>
      ))}
    </div>
  </div>
</section>

<style>
.au-head { text-align:center;margin-bottom:3rem; }
.au-head h2 { color:#111827;margin-bottom:.75rem; }
.au-sub { max-width:52ch;margin:0 auto;color:#6B7280; }

/* GRID */
.au-grid {
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:1.5px;
}

/* CARD */
.au-card {
  padding:2.5rem;
  border:1px solid #E5E7EB;
  background:#fff;
  transition:all .3s ease;
  display:flex;
  flex-direction:column;
  gap:.9rem;
  position:relative;
}

/* TOP BORDER COLORS */
.ac-red    { border-top:3px solid #CC1417; }
.ac-orange { border-top:3px solid #E8601A; }
.ac-teal   { border-top:3px solid #006D77; }
.ac-gold   { border-top:3px solid #C8960C; }

.au-card:hover {
  box-shadow:0 12px 36px rgba(0,0,0,.08);
  transform:translateY(-3px);
}

/* HEADER */
.ac-top {
  display:flex;
  align-items:center;
  gap:10px;
}

.ac-icon { font-size:1.2rem; }

.ac-label {
  font-size:.7rem;
  font-weight:700;
  letter-spacing:.12em;
  text-transform:uppercase;
}

/* TITLE (HOOK) */
.ac-title {
  font-family:'Nunito Sans',sans-serif;
  font-size:clamp(1.2rem,2.5vw,1.6rem);
  font-weight:800;
  text-transform:uppercase;
  color:#111827;
  line-height:1.2;
  margin-top:.2rem;
}

/* BODY */
.ac-body {
  font-size:.92rem;
  color:#6B7280;
  line-height:1.75;
  flex:1;
}

/* POINTS */
.ac-points {
  list-style:none;
  display:flex;
  flex-direction:column;
  gap:6px;
}

.ac-points li {
  font-size:.82rem;
  color:#4B5563;
  padding-left:16px;
  position:relative;
  line-height:1.5;
}

.ac-points li::before {
  content:'✓';
  position:absolute;
  left:0;
  font-size:.7rem;
}

.ac-red    .ac-points li::before { color:#CC1417; }
.ac-orange .ac-points li::before { color:#E8601A; }
.ac-teal   .ac-points li::before { color:#006D77; }
.ac-gold   .ac-points li::before { color:#C8960C; }

/* CTA */
.ac-link {
  display:inline-flex;
  align-items:center;
  gap:5px;
  font-size:.76rem;
  font-weight:700;
  text-transform:uppercase;
  letter-spacing:.08em;
  text-decoration:none;
  transition:gap .2s;
}

.ac-link:hover { gap:9px; }

/* COLORS */
.al-red    { color:#CC1417; }
.al-orange { color:#E8601A; }
.al-teal   { color:#006D77; }
.al-gold   { color:#C8960C; }

/* MOBILE */
@media(max-width:768px){
  .au-grid{grid-template-columns:1fr}
  .au-card{padding:1.75rem}
}
</style>