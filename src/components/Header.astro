<header class="site-header">
  <div class="container header-inner">

    <!-- LOGO -->
    <a href="/" class="logo-wrap">
      <img src="/logo.png" alt="Tecil Solar" />
    </a>

    <!-- NAV -->
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/services">Services</a>
      <a href="/projects">Projects</a>
      <a href="/contact">Contact</a>
    </nav>

  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  background: #ffffff;
  border-bottom: 1px solid #eee;
  z-index: 1000;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 70px;
}

/* LOGO FIXED */
.logo-wrap img {
  height: 42px;
  width: auto;
  display: block;
}

/* NAV */
.nav {
  display: flex;
  gap: 24px;
}

.nav a {
  text-decoration: none;
  font-weight: 600;
  color: #111;
  position: relative;
}

/* HOVER FIX */
.nav a::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: -4px;
  width: 0%;
  height: 2px;
  background: #CC1417;
  transition: 0.3s;
}

.nav a:hover::after {
  width: 100%;
}
</style>i