---
interface Slide {
  src: string;
  alt: string;
  caption?: string;
  label?: string;
}

const {
  slides,
  autoplay = 5000,
  id = 'slider-' + Math.random().toString(36).slice(2,8),
} = Astro.props;
---

<div class="ultra-slider" id={id} tabindex="0">
  <div class="track">
    {slides.map((s, i) => (
      <div class={`slide ${i === 0 ? 'active' : ''}`}>
        <img src={s.src} alt={s.alt} class="img" />

        <div class="overlay"></div>

        <div class="content">
          {s.label && <span class="label">{s.label}</span>}
          {s.caption && <p class="caption">{s.caption}</p>}
        </div>
      </div>
    ))}
  </div>

  <button class="nav prev">‹</button>
  <button class="nav next">›</button>

  <div class="dots">
    {slides.map((_, i) => (
      <button class={`dot ${i===0?'active':''}`} data-i={i}></button>
    ))}
  </div>

  <div class="progress"><div class="bar"></div></div>
</div>

<style>
.ultra-slider {
  position:relative;
  overflow:hidden;
  height: clamp(320px, 50vw, 600px);
}

/* SLIDES */
.slide {
  position:absolute; inset:0;
  opacity:0;
  transform:scale(1.08);
  transition:opacity 1s ease, transform 1.6s ease;
}
.slide.active {
  opacity:1;
  transform:scale(1);
  z-index:2;
}

/* IMAGE (parallax feel) */
.img {
  width:100%; height:100%;
  object-fit:cover;
  transform:scale(1.1);
  transition:transform 6s ease;
}
.slide.active .img {
  transform:scale(1);
}

/* OVERLAY */
.overlay {
  position:absolute; inset:0;
  background:linear-gradient(to top, rgba(0,0,0,.75), transparent);
}

/* CONTENT */
.content {
  position:absolute;
  bottom:3rem; left:2rem;
  color:#fff;
  max-width:500px;
}

/* TEXT ANIMATION */
.label, .caption {
  opacity:0;
  transform:translateY(20px);
}
.slide.active .label {
  animation:fadeUp .6s ease .2s forwards;
}
.slide.active .caption {
  animation:fadeUp .8s ease .35s forwards;
}

@keyframes fadeUp {
  to {
    opacity:1;
    transform:translateY(0);
  }
}

.label {
  font-size:.7rem;
  text-transform:uppercase;
  color:#ff6a00;
  font-weight:700;
}

.caption {
  font-size:.95rem;
  opacity:.9;
}

/* NAV */
.nav {
  position:absolute; top:50%;
  transform:translateY(-50%);
  width:44px; height:44px;
  border-radius:50%;
  background:rgba(0,0,0,.4);
  color:#fff;
  border:none;
  cursor:pointer;
  opacity:0;
}
.ultra-slider:hover .nav { opacity:1; }
.prev { left:12px; }
.next { right:12px; }

/* DOTS */
.dots {
  position:absolute;
  bottom:14px;
  left:50%;
  transform:translateX(-50%);
  display:flex;
  gap:6px;
}
.dot {
  width:6px; height:6px;
  background:#aaa;
  border-radius:50%;
}
.dot.active {
  width:20px;
  border-radius:4px;
  background:#fff;
}

/* PROGRESS */
.progress {
  position:absolute;
  bottom:0; left:0; right:0;
  height:3px;
  background:rgba(255,255,255,.1);
}
.bar {
  width:0%;
  height:100%;
  background:#ff6a00;
}

/* MOBILE */
@media(max-width:600px){
  .content { left:1rem; bottom:2rem; }
}
</style>

<script define:vars={{ id, autoplay }}>
(() => {
  const root = document.getElementById(id);
  if (!root) return;

  const slides = root.querySelectorAll('.slide');
  const dots   = root.querySelectorAll('.dot');
  const bar    = root.querySelector('.bar');

  let i=0, timer, paused=false, startX=0;

  function show(n){
    slides[i].classList.remove('active');
    dots[i].classList.remove('active');

    i = (n + slides.length) % slides.length;

    slides[i].classList.add('active');
    dots[i].classList.add('active');

    resetBar();
  }

  function next(){ show(i+1); }
  function prev(){ show(i-1); }

  function resetBar(){
    bar.style.transition='none';
    bar.style.width='0%';
    requestAnimationFrame(()=>{
      bar.style.transition=`width ${autoplay}ms linear`;
      bar.style.width='100%';
    });
  }

  function start(){
    stop();
    timer=setInterval(()=>{ if(!paused) next(); }, autoplay);
    resetBar();
  }

  function stop(){ clearInterval(timer); }

  // Controls
  root.querySelector('.next').onclick=()=>{ next(); start(); };
  root.querySelector('.prev').onclick=()=>{ prev(); start(); };

  dots.forEach((d,idx)=>{
    d.onclick=()=>{ show(idx); start(); };
  });

  // Hover pause
  root.onmouseenter=()=> paused=true;
  root.onmouseleave=()=> paused=false;

  // Swipe (smooth)
  root.addEventListener('pointerdown',e=>startX=e.clientX);
  root.addEventListener('pointerup',e=>{
    let diff=e.clientX-startX;
    if(diff>60) prev();
    if(diff<-60) next();
  });

  // Keyboard
  root.onkeydown=e=>{
    if(e.key==='ArrowRight') next();
    if(e.key==='ArrowLeft') prev();
  };

  // Pause when offscreen (IntersectionObserver)
  const io = new IntersectionObserver(entries=>{
    entries.forEach(entry=>{
      paused = !entry.isIntersecting;
    });
  },{threshold:.3});
  io.observe(root);

  // Tab visibility
  document.addEventListener('visibilitychange',()=>{
    paused=document.hidden;
  });

  start();
})();
</script>