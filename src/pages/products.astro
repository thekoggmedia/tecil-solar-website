---
import Layout from '../layouts/Layout.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import CTASection from '../components/CTASection.astro';

const categories = [
  { id: "panels", name: "Solar Panels", range: "20W – 600W", desc: "Monocrystalline, polycrystalline, and half-cut crystalline panels for residential, commercial, and industrial applications.", specs: ["Monocrystalline (high efficiency)", "Polycrystalline (cost-effective)", "Half-Cut technology (shade tolerant)", "20W residential to 600W commercial"] },
  { id: "inverters", name: "Inverters", range: "1KVA – 50KVA", desc: "Pure sinewave transformer-based inverters and Solar Hybrid configurations — both transformer and transformerless types.", specs: ["Pure sinewave output", "Transformer & transformerless types", "Solar hybrid configurations", "1KVA home to 50KVA industrial"] },
  { id: "batteries", name: "Batteries", range: "100AH – 200AH / 1.2kWh – 60kWh", desc: "Gel Sealed Deep Cycle, Tubular Wet-cell, and Lithium-ion Phosphate (LiFePO4) battery systems.", specs: ["Gel Sealed Deep Cycle", "Tubular Wet-cell (long life)", "LiFePO4 (premium performance)", "1.2kWh to 60kWh systems"] },
  { id: "controllers", name: "Charge Controllers", range: "10A – 150A", desc: "PWM and MPPT charge controllers for maximum system efficiency and battery protection.", specs: ["PWM (cost-effective)", "MPPT (higher efficiency, up to 30% gain)", "10A to 150A capacity", "Multi-stage charging algorithms"] },
  { id: "lights", name: "Solar Lights", range: "10W – 300W", desc: "All-in-One Solar Street Lights, Floodlights, Garden Lights, and Solar Bulbs for outdoor and interior applications.", specs: ["All-in-One street lights", "Commercial floodlights", "Garden & landscape lights", "Solar replacement bulbs"] },
  { id: "stabilisers", name: "Voltage Stabilisers", range: "5KVA – 300KVA", desc: "Relay and servo technology Automatic Voltage Regulators (AVRs) for equipment protection across all scale applications.", specs: ["Relay technology AVRs", "Servo motor stabilisers", "Single & three phase", "5KVA home to 300KVA industrial"] },
  { id: "accessories", name: "Solar Accessories", range: "Various", desc: "Complete range of solar system accessories: racking, cables, breakers, and protection equipment.", specs: ["Mounting racks & profiles", "DC & AC cables", "MCBs & isolators", "Surge arrestors & earthing"] },
];

const brands = ["Tsolar","Felicity Solar","Smarten","Ecoflow","Restar","Jinko Solar","Dique","Deye","Oraimo","itel","Longi Solar"];
---

<Layout title="Products — TECIL Solar" description="Full solar product portfolio: panels, inverters, batteries, charge controllers, solar lights, and accessories. 15+ authorised brand partnerships." page="products">

  <section class="page-hero">
    <div class="ph-bg"></div>
    <div class="ph-orb"></div>
    <div class="container">
      <span class="section-tag">Product Range</span>
      <h1>Complete Solar <span class="text-red-gradient">Product Portfolio</span></h1>
      <p class="ph-sub">From entry-level residential panels to industrial-grade hybrid systems. Authorised by 15+ world-class international brands.</p>
    </div>
  </section>

  <MarqueeStrip variant="red" />

  <!-- Products Grid -->
  <section class="products-full dark-2-section section">
    <div class="container">
      <div class="prod-grid">
        {categories.map((cat, i) => (
          <div id={cat.id} class={`prod-card reveal reveal-delay-${i % 3}`}>
            <div class="pc-header">
              <h3 class="pc-name">{cat.name}</h3>
              <span class="pc-range">{cat.range}</span>
            </div>
            <p class="pc-desc">{cat.desc}</p>
            <ul class="pc-specs">
              {cat.specs.map(s => <li>{s}</li>)}
            </ul>
            <a href="/contact" class="pc-enquire">Enquire →</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Brand Partners -->
  <section class="brands-section dark-section section">
    <div class="container">
      <div class="brands-header">
        <span class="section-tag">Authorised Partnerships</span>
        <h2>15+ World-Class <span class="text-red-gradient">Brand Partners</span></h2>
        <p class="brands-sub">We are an authorised distributor or partner for the following international solar and energy brands — giving you access to genuine products with valid warranties.</p>
      </div>
      <div class="brands-grid">
        {brands.map(b => (
          <div class="brand-tile reveal">{b}</div>
        ))}
        <div class="brand-tile brand-plus reveal">+ More</div>
      </div>
    </div>
  </section>

  <CTASection />

</Layout>

<style>
  .page-hero {
    min-height: 40vh; background: #111;
    display: flex; align-items: center;
    padding: 120px 5% 80px;
    position: relative; overflow: hidden;
  }
  .ph-bg {
    position: absolute; inset: 0;
    background-image: linear-gradient(rgba(204,20,23,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(204,20,23,0.04) 1px, transparent 1px);
    background-size: 64px 64px;
  }
  .ph-orb {
    position: absolute; border-radius: 50%; filter: blur(80px); pointer-events: none;
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(204,20,23,0.1) 0%, transparent 70%);
    top: -100px; right: -50px;
  }
  .page-hero .container { position: relative; z-index: 1; }
  .page-hero h1 { color: #fff; margin: 8px 0 16px; }
  .ph-sub { font-size: 1.05rem; color: rgba(255,255,255,0.5); max-width: 560px; line-height: 1.75; }

  .prod-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
  }

  .prod-card {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 2.25rem 2rem;
    position: relative; overflow: hidden;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
    display: flex; flex-direction: column; gap: 1rem;
  }
  .prod-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, #CC1417, #E8601A);
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s ease;
  }
  .prod-card:hover {
    border-color: rgba(232,96,26,0.25); transform: translateY(-3px);
    background: rgba(232,96,26,0.04);
  }
  .prod-card:hover::before { transform: scaleX(1); }

  .pc-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; flex-wrap: wrap; }
  .pc-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 1.2rem; font-weight: 800;
    text-transform: uppercase; color: #fff;
  }
  .pc-range {
    background: rgba(200,150,12,0.1);
    border: 1px solid rgba(200,150,12,0.25);
    color: #C8960C;
    font-size: 0.68rem; font-weight: 700;
    padding: 3px 10px; border-radius: 2px;
    white-space: nowrap; letter-spacing: 0.04em;
  }
  .pc-desc { font-size: 0.86rem; color: rgba(255,255,255,0.5); line-height: 1.7; }
  .pc-specs { list-style: none; display: flex; flex-direction: column; gap: 5px; flex: 1; }
  .pc-specs li {
    font-size: 0.8rem; color: rgba(255,255,255,0.45);
    padding-left: 14px; position: relative; line-height: 1.5;
  }
  .pc-specs li::before { content: '◆'; position: absolute; left: 0; color: #E8601A; font-size: 0.4rem; top: 5px; }
  .pc-enquire {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem; font-weight: 700;
    color: #E8601A; text-decoration: none;
    letter-spacing: 0.08em; text-transform: uppercase;
    transition: color 0.2s;
  }
  .pc-enquire:hover { color: #CC1417; }

  .brands-section { background: #111; }
  .brands-header { text-align: center; margin-bottom: 3rem; }
  .brands-header h2 { color: #fff; margin-bottom: 1rem; }
  .brands-sub { max-width: 560px; margin: 0 auto; color: rgba(255,255,255,0.5); }
  .brands-grid {
    display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
  }
  .brand-tile {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.55);
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem; font-weight: 600;
    padding: 10px 22px; border-radius: 2px;
    letter-spacing: 0.04em;
    transition: all 0.3s ease;
  }
  .brand-tile:hover {
    background: rgba(232,96,26,0.08);
    border-color: rgba(232,96,26,0.25);
    color: #E8601A;
  }
  .brand-plus {
    background: rgba(204,20,23,0.08) !important;
    border-color: rgba(204,20,23,0.2) !important;
    color: #CC1417 !important;
  }

  @media (max-width: 900px) { .prod-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .prod-grid { grid-template-columns: 1fr; } }
</style>
