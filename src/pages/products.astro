---
import Layout from '../layouts/Layout.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import CTASection from '../components/CTASection.astro';
import { products } from '../data/site';
---

<Layout
  title="Products — TECIL Solar"
  description="Solar panels, inverters, batteries, controllers, lighting, and accessories from TECIL Solar."
  page="products"
>
  <section class="page-hero">
    <div class="page-hero-grid"></div>
    <div class="page-hero-orb a"></div>
    <div class="page-hero-orb b"></div>
    <div class="container">
      <span class="section-tag">Products</span>
      <h1>Show the actual products you sell.</h1>
      <p class="page-hero-sub">
        This page turns the site into a sales page instead of only an information page.
      </p>
    </div>
  </section>

  <MarqueeStrip variant="red" />

  <section class="section bg-white">
    <div class="container">
      <div class="product-grid">
        {products.map((item, index) => (
          <article class:list={['product-card', 'card', 'reveal', `reveal-delay-${(index % 5) + 1}`]} id={
            item.category.toLowerCase().includes('panel') ? 'panels' :
            item.category.toLowerCase().includes('inverter') ? 'inverters' :
            item.category.toLowerCase().includes('battery') ? 'batteries' :
            item.category.toLowerCase().includes('controller') ? 'controllers' :
            item.category.toLowerCase().includes('lighting') ? 'lighting' : 'accessories'
          }>
            <span class="product-kicker">{item.category}</span>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
            <ul>
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-off">
    <div class="container">
      <div class="buying-shell reveal">
        <div>
          <span class="section-tag">What To Buy First</span>
          <h2>Guide visitors toward the right product combination.</h2>
        </div>
        <div class="buying-box">
          <p>
            When you present panels, inverters, batteries, and accessories in grouped categories, the page feels
            clearer and easier to buy from.
          </p>
          <p>
            That structure also helps the MD see the business as a seller of real products, not only a service provider.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .product-card {
    padding: 1.45rem;
  }

  .product-kicker {
    display: inline-flex;
    margin-bottom: 0.8rem;
    padding: 0.5rem 0.72rem;
    border-radius: 999px;
    background: rgba(232,96,26,0.10);
    color: var(--orange);
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .product-card h3 {
    font-size: 1.55rem;
  }

  .product-card p {
    margin-top: 0.6rem;
  }

  .product-card ul {
    margin: 1rem 0 0;
    padding-left: 1.1rem;
    color: var(--muted);
  }

  .product-card li + li {
    margin-top: 0.4rem;
  }

  .buying-shell {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.4rem;
    align-items: start;
  }

  .buying-shell h2 {
    max-width: 11ch;
  }

  .buying-box {
    padding: 1.35rem;
    border-radius: 28px;
    border: 1px solid var(--border);
    background: #fff;
  }

  .buying-box p + p {
    margin-top: 0.85rem;
  }

  @media (max-width: 980px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .buying-shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>