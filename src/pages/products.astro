---
import Layout from '../layouts/Layout.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import CTASection from '../components/CTASection.astro';
import BrandsStrip from '../components/BrandsStrip.astro';

// Google Sheet — Product Library tab
const SHEET_ID  = '1O13BFsTZflUc-B5ZPjXuJUparLHP9GBip6psVVED99E';
const SHEET_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json&sheet=Product%20Library`;

// Exact categories from the sheet
const CATEGORIES = [
  'Inverter',
  'Battery',
  'Solar Panel',
  'Charge Controller',
  'Solar Light',
  'Solar Generator',
];
---

<Layout
  title="Products — TECIL Solar"
  description="Browse 69+ products — inverters, batteries, solar panels, charge controllers, lighting and generators from 15+ authorised brands. Live pricing from Calabar."
  page="products"
>

  <!-- ── HERO ── -->
  <section class="page-hero">
    <div class="page-hero-grid"></div>
    <div class="page-hero-orb a"></div>
    <div class="page-hero-orb b"></div>
    <div class="container">
      <span class="section-tag">Products</span>
      <h1>69 Products.<br/><span class="text-gradient">Live Pricing.</span></h1>
      <p class="page-hero-sub">
        Solar panels, hybrid inverters, lithium batteries, charge controllers, solar lighting
        and generators — from 15+ authorised brands. All prices are live from our Calabar
        branch and updated regularly.
      </p>
      <div class="hero-btns">
        <a href="#product-section" class="btn-primary">Browse Products</a>
        <a href="/contact" class="btn-outline-white">Get a Free Quote</a>
      </div>
    </div>
  </section>

  <MarqueeStrip variant="red" />

  <!-- ── STATS BAR ── -->
  <div class="pstats-bar">
    <div class="container pstats-inner">
      {[
        { val:'69',   label:'Products in Stock' },
        { val:'6',    label:'Product Categories' },
        { val:'15+',  label:'Authorised Brands' },
        { val:'Live', label:'Pricing Updated Daily' },
      ].map(s => (
        <div class="pstat-item">
          <strong>{s.val}</strong>
          <span>{s.label}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ── FILTER + SEARCH BAR ── -->
  <div class="filter-bar" id="filter-bar">
    <div class="container fb-inner">

      <!-- CATEGORY TABS -->
      <div class="filter-tabs" id="filter-tabs">
        <button class="ftab is-active" data-cat="all">All Products</button>
        {CATEGORIES.map(c => (
          <button class="ftab" data-cat={c}>{c}s</button>
        ))}
      </div>

      <!-- SEARCH + FILTERS -->
      <div class="fb-right">
        <div class="fb-search">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" id="product-search" placeholder="Search name, brand, capacity…" autocomplete="off"/>
          <button id="search-clear" class="sc-btn" style="display:none" aria-label="Clear">✕</button>
        </div>
        <select id="brand-filter" class="fb-select">
          <option value="">All Brands</option>
        </select>
        <select id="sort-filter" class="fb-select">
          <option value="">Sort: Default</option>
          <option value="price-asc">Price: Low → High</option>
          <option value="price-desc">Price: High → Low</option>
          <option value="name-asc">Name: A → Z</option>
        </select>
      </div>

    </div>
  </div>

  <!-- ── PRODUCT SECTION ── -->
  <section class="section bg-off" id="product-section">
    <div class="container">

      <div id="products-loading" class="state-box">
        <div class="spin"></div>
        <p>Loading live catalogue…</p>
      </div>

      <div id="products-error" class="state-box" style="display:none">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#CC1417" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12" y2="16.01"/></svg>
        <p>Could not load products right now.</p>
        <a href="/contact" class="btn-primary" style="margin-top:1rem">Contact Us for Pricing</a>
      </div>

      <div id="products-empty" class="state-box" style="display:none">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.8"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <p>No products match your search.</p>
        <button onclick="window.resetFilters()" class="btn-primary" style="margin-top:1rem">Clear Filters</button>
      </div>

      <div id="products-meta" class="products-meta" style="display:none"></div>
      <div id="products-grid" class="product-grid" style="display:none"></div>

    </div>
  </section>

  <BrandsStrip variant="light" />

  <!-- ── BUYING GUIDE ── -->
  <section class="section bg-dark">
    <div class="container">
      <div class="guide-grid reveal">
        <div class="guide-copy">
          <span class="section-tag">Buying Guide</span>
          <h2>Not Sure What <span class="text-gradient">You Need?</span></h2>
          <p>
            Solar systems are not one-size-fits-all. The right panel wattage, inverter
            capacity, and battery bank depends on your actual load — not guesswork.
            Our engineers will assess your site and recommend the right combination
            before you spend a naira.
          </p>
          <div class="guide-steps">
            {[
              { n:'01', t:'Tell us your load',       d:'Appliances, usage hours, priority items' },
              { n:'02', t:'We size your system',     d:'Panel wattage, inverter KVA, battery AH' },
              { n:'03', t:'We quote transparently',  d:'Full BOQ with brand options and pricing' },
              { n:'04', t:'We install & commission', d:'Documented handover with system baseline' },
            ].map(s => (
              <div class="gs-row">
                <span class="gs-n">{s.n}</span>
                <div>
                  <strong class="gs-t">{s.t}</strong>
                  <span class="gs-d">{s.d}</span>
                </div>
              </div>
            ))}
          </div>
          <a href="/contact" class="btn-primary" style="margin-top:1.75rem">
            Get a Free Assessment
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="guide-warranty">
          <div class="gw-card">
            <div class="gw-icon">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#CC1417" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </div>
            <h3>Our Quality Promise</h3>
            <ul class="gw-list">
              {[
                'All products from authorised channels only',
                'Full manufacturer warranty honoured',
                'Installation backed by TECIL guarantee',
                'Technical support after every installation',
                'Honest advice — we recommend what fits your budget',
                'No counterfeit or grey-market products. Ever.',
              ].map(p => (
                <li>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#CC1417" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                  {p}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />

</Layout>

<!-- ─────────────────── STYLES ─────────────────── -->
<style>
.hero-btns { display:flex; gap:12px; margin-top:2rem; flex-wrap:wrap; }

/* STATS BAR */
.pstats-bar { background:#fff; border-bottom:1px solid #E5E7EB; }
.pstats-inner { display:flex; flex-wrap:wrap; justify-content:center; }
.pstat-item {
  display:flex; flex-direction:column; align-items:center;
  padding:1.25rem 2.5rem; border-right:1px solid #E5E7EB; gap:3px;
}
.pstat-item:last-child { border-right:none; }
.pstat-item strong {
  font-family:var(--font); font-size:1.9rem; font-weight:900; color:#CC1417; line-height:1;
  font-variation-settings:'wdth' 125,'wght' 900;
}
.pstat-item span { font-size:.62rem; font-weight:600; color:#6B7280; text-transform:uppercase; letter-spacing:.07em; text-align:center; }

/* FILTER BAR */
.filter-bar {
  background:#fff; border-bottom:1px solid #E5E7EB;
  position:sticky; top:68px; z-index:90;
}
.fb-inner {
  display:flex; align-items:center; justify-content:space-between;
  gap:1rem; padding-top:.65rem; padding-bottom:.65rem; flex-wrap:wrap;
}
.filter-tabs { display:flex; gap:4px; flex-wrap:wrap; }
.ftab {
  padding:.4rem .85rem; border-radius:6px; font-size:.7rem; font-weight:700;
  border:1.5px solid #E5E7EB; background:#fff; cursor:pointer; color:#6B7280;
  letter-spacing:.05em; text-transform:uppercase; transition:all .2s ease;
  font-variation-settings:'wdth' 100,'wght' 700; white-space:nowrap;
}
.ftab:hover   { border-color:rgba(204,20,23,.3); color:#CC1417; }
.ftab.is-active { background:#CC1417; border-color:#CC1417; color:#fff; }

.fb-right { display:flex; align-items:center; gap:8px; flex-wrap:wrap; }
.fb-search {
  display:flex; align-items:center; gap:7px;
  padding:.4rem .85rem; border:1.5px solid #E5E7EB; border-radius:6px;
  background:#F7F8FA; min-width:220px; transition:border-color .2s;
}
.fb-search:focus-within { border-color:rgba(204,20,23,.4); background:#fff; }
.fb-search svg { color:#9CA3AF; flex-shrink:0; }
.fb-search input { border:none; background:transparent; font-size:.8rem; color:#111827; outline:none; width:100%; }
.fb-search input::placeholder { color:#9CA3AF; }
.sc-btn { background:none; border:none; cursor:pointer; color:#9CA3AF; font-size:.8rem; padding:0 2px; line-height:1; }
.sc-btn:hover { color:#CC1417; }

.fb-select {
  padding:.4rem .75rem; border:1.5px solid #E5E7EB; border-radius:6px;
  background:#F7F8FA; font-size:.75rem; font-weight:600; color:#4B5563;
  cursor:pointer; outline:none; transition:border-color .2s;
  font-variation-settings:'wdth' 100,'wght' 600;
}
.fb-select:focus { border-color:rgba(204,20,23,.4); }

/* STATES */
.state-box {
  display:flex; flex-direction:column; align-items:center; justify-content:center;
  gap:14px; padding:5rem 2rem; text-align:center; min-height:300px;
}
.state-box p { font-size:.95rem; color:#6B7280; }
.spin {
  width:36px; height:36px; border:3px solid #F3F4F6; border-top-color:#CC1417;
  border-radius:50%; animation:spin .75s linear infinite;
}
@keyframes spin { to { transform:rotate(360deg) } }

/* META */
.products-meta {
  font-size:.75rem; color:#9CA3AF; font-weight:500; margin-bottom:1.25rem;
  letter-spacing:.04em; text-transform:uppercase;
}

/* ── PRODUCT GRID ── */
.product-grid {
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:0;
  border:1px solid #E5E7EB;
  border-radius:12px;
  overflow:hidden;
  background:#E5E7EB; /* acts as gap colour */
}

/* ── PRODUCT CARD ── */
.pcard {
  background:#fff;
  display:flex; flex-direction:column;
  transition:all .3s ease;
  position:relative; overflow:hidden;
}
.pcard::after {
  content:''; position:absolute; top:0; left:0; right:0; height:3px;
  background:linear-gradient(90deg,#CC1417,#E8601A);
  transform:scaleX(0); transform-origin:left; transition:transform .3s ease;
}
.pcard:hover { transform:translateY(-3px); box-shadow:0 12px 36px rgba(0,0,0,.12); z-index:2; }
.pcard:hover::after { transform:scaleX(1); }

/* IMAGE AREA */
.pcard-img-wrap {
  width:100%; aspect-ratio:4/3; overflow:hidden;
  background:linear-gradient(145deg,#F7F8FA 0%,#EDEEF0 100%);
  position:relative; flex-shrink:0;
}
.pcard-img {
  width:100%; height:100%; object-fit:contain; display:block;
  padding:1rem;
  transition:transform .4s ease;
}
.pcard:hover .pcard-img { transform:scale(1.05); }
.pcard-img-ph {
  width:100%; height:100%; display:flex; flex-direction:column;
  align-items:center; justify-content:center; gap:10px;
}
.pcard-img-ph .ph-icon { color:#D1D5DB; }
.pcard-img-ph .ph-cat {
  font-size:.6rem; font-weight:800; text-transform:uppercase;
  letter-spacing:.12em; color:#C4C9D4;
  font-variation-settings:'wdth' 100,'wght' 800;
}
.pcard-img-ph .ph-brand {
  font-size:.72rem; font-weight:700; color:#9CA3AF;
  font-variation-settings:'wdth' 100,'wght' 700;
}

/* CARD TYPE TAG (top-left overlay) */
.pcard-type-tag {
  position:absolute; bottom:8px; left:8px;
  background:rgba(0,0,0,.55); backdrop-filter:blur(4px);
  color:rgba(255,255,255,.9); font-size:.56rem; font-weight:700;
  text-transform:uppercase; letter-spacing:.08em;
  padding:3px 8px; border-radius:4px;
  font-variation-settings:'wdth' 100,'wght' 700;
}

/* CARD BODY */
.pcard-body {
  padding:1.1rem 1.25rem 1.25rem;
  display:flex; flex-direction:column; gap:.45rem; flex:1;
}

/* CATEGORY CHIP */
.pcard-cat {
  display:inline-flex; font-size:.58rem; font-weight:800;
  padding:3px 9px; border-radius:999px;
  text-transform:uppercase; letter-spacing:.07em; width:fit-content;
  font-variation-settings:'wdth' 100,'wght' 800;
}
.cat-Inverter        { background:#FFF1F1; color:#CC1417; }
.cat-Battery         { background:#EDF7F8; color:#006D77; }
.cat-Solar-Panel     { background:#FFFBEA; color:#C8960C; }
.cat-Charge-Controller { background:#FFF5EE; color:#E8601A; }
.cat-Solar-Light     { background:#F0FDF4; color:#166534; }
.cat-Solar-Generator { background:#EFF6FF; color:#1D4ED8; }

/* NAME */
.pcard-name {
  font-family:var(--font); font-size:.9rem; font-weight:800;
  color:#111827; line-height:1.25; letter-spacing:.01em;
  font-variation-settings:'wdth' 125,'wght' 800;
}

/* BRAND */
.pcard-brand {
  font-size:.68rem; font-weight:700; color:#9CA3AF;
  text-transform:uppercase; letter-spacing:.06em;
  font-variation-settings:'wdth' 100,'wght' 700;
}

/* CAPACITY BADGE */
.pcard-capacity {
  display:inline-flex; align-items:center; gap:5px;
  background:#F7F8FA; border:1px solid #E5E7EB;
  padding:4px 10px; border-radius:6px; width:fit-content;
  font-size:.72rem; font-weight:700; color:#374151;
  font-variation-settings:'wdth' 100,'wght' 700;
}
.pcard-capacity svg { color:#CC1417; flex-shrink:0; }

/* FOOTER */
.pcard-footer {
  display:flex; align-items:center; justify-content:space-between;
  padding-top:.85rem; margin-top:auto;
  border-top:1px solid #F3F4F6; gap:.5rem;
}
.pcard-price {
  font-family:var(--font); font-size:1.25rem; font-weight:900; color:#CC1417; line-height:1;
  font-variation-settings:'wdth' 125,'wght' 900;
}
.pcard-price-label {
  font-size:.56rem; font-weight:600; color:#9CA3AF;
  text-transform:uppercase; letter-spacing:.06em; display:block; margin-top:1px;
}
.pcard-enquire {
  display:inline-flex; align-items:center; gap:5px;
  font-size:.68rem; font-weight:800; letter-spacing:.06em;
  text-transform:uppercase; color:#fff; background:#CC1417;
  padding:.45rem .9rem; border-radius:6px; text-decoration:none;
  transition:all .2s ease; white-space:nowrap;
  font-variation-settings:'wdth' 100,'wght' 800;
}
.pcard-enquire:hover { background:#B01215; transform:translateY(-1px); }

/* GUIDE */
.guide-grid { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:start; }
.guide-copy h2 { color:#fff; margin-bottom:1rem; }
.guide-copy > p { color:rgba(255,255,255,.6); line-height:1.85; margin-bottom:1.5rem; }
.guide-steps { display:flex; flex-direction:column; }
.gs-row { display:flex; align-items:flex-start; gap:14px; padding:.85rem 0; border-bottom:1px solid rgba(255,255,255,.07); }
.gs-row:last-child { border-bottom:none; }
.gs-n { font-family:var(--font); font-size:1.4rem; font-weight:900; color:rgba(204,20,23,.4); line-height:1; flex-shrink:0; width:32px; font-variation-settings:'wdth' 125,'wght' 900; }
.gs-t { display:block; font-size:.88rem; font-weight:700; color:#fff; margin-bottom:2px; font-variation-settings:'wdth' 100,'wght' 700; }
.gs-d { font-size:.78rem; color:rgba(255,255,255,.4); }
.guide-warranty { padding-top:1rem; }
.gw-card { background:rgba(255,255,255,.05); border:1px solid rgba(204,20,23,.2); border-radius:16px; padding:2rem; }
.gw-icon { width:52px; height:52px; background:rgba(204,20,23,.12); border-radius:12px; display:flex; align-items:center; justify-content:center; margin-bottom:1rem; }
.gw-card h3 { font-family:var(--font); font-size:1.05rem; font-weight:800; text-transform:uppercase; color:#fff; margin-bottom:1rem; letter-spacing:.02em; font-variation-settings:'wdth' 125,'wght' 800; }
.gw-list { list-style:none; display:flex; flex-direction:column; gap:10px; }
.gw-list li { display:flex; align-items:flex-start; gap:8px; font-size:.82rem; color:rgba(255,255,255,.65); line-height:1.5; }
.gw-list li svg { flex-shrink:0; margin-top:3px; }

/* RESPONSIVE */
@media(max-width:1080px) { .product-grid { grid-template-columns:repeat(2,1fr); } }
@media(max-width:900px)  {
  .guide-grid { grid-template-columns:1fr; gap:3rem; }
  .filter-bar { position:relative; top:auto; }
  .fb-inner { flex-direction:column; align-items:flex-start; }
  .fb-right { width:100%; }
  .fb-search { flex:1; }
}
@media(max-width:600px)  {
  .product-grid { grid-template-columns:1fr; }
  .pstat-item { padding:.85rem 1.25rem; }
}
</style>

<!-- ─────────────────── SCRIPT ─────────────────── -->
<script define:vars={{ SHEET_URL }}>
// ── EXACT COLUMN INDICES (from the sheet we read) ──
// Row 1 (header): Product ID | Category | Brand | Model Name / Description |
//                 Capacity / Power / Size | Product Type | Quick Name |
//                 Price — Calabar (NGN) | Price Last Updated | Drive Folder URL |
//                 Hero JPEG URL | PNG Transparent URL | SVG Card URL | WebP URL |
//                 Website Page URL | Branches in Stock | Pricing Notes | Date Photographed | Status
const COL = {
  id:         0,
  category:   1,
  brand:      2,
  modelName:  3,   // "Model Name / Description"
  capacity:   4,   // "Capacity / Power / Size"
  type:       5,   // "Product Type"
  quickName:  6,   // "Quick Name"
  price:      7,   // "Price — Calabar (NGN)"
  heroJpeg:  10,   // "Hero JPEG URL"
  pngUrl:    11,   // "PNG Transparent URL"
  webpUrl:   13,   // "WebP URL"
  status:    18,   // "Status"
};

// ── STATE ──
let allProducts    = [];
let activeCategory = 'all';
let searchQuery    = '';
let activeBrand    = '';
let sortMode       = '';

// ── HELPERS ──
function cell(row, idx) {
  const c = row.c?.[idx];
  if (!c || c.v === null || c.v === undefined) return '';
  return String(c.v).trim();
}

function formatPrice(raw) {
  const n = parseFloat(String(raw).replace(/[^0-9.]/g, ''));
  if (!n || n === 0) return null;
  if (n >= 1_000_000) return '₦' + (n / 1_000_000).toFixed(1).replace('.0','') + 'M';
  if (n >= 1_000)     return '₦' + n.toLocaleString('en-NG');
  return '₦' + n;
}

function getBestImage(row) {
  // Try images in priority order: WebP → Hero JPEG → PNG Transparent
  return cell(row, COL.webpUrl)
      || cell(row, COL.heroJpeg)
      || cell(row, COL.pngUrl)
      || '';
}

function catClass(cat) {
  return 'cat-' + cat.replace(/\s+/g, '-');
}

// ── CARD HTML ──
function buildCard(row) {
  const id       = cell(row, COL.id);
  const category = cell(row, COL.category);
  const brand    = cell(row, COL.brand);
  const name     = cell(row, COL.modelName) || cell(row, COL.quickName) || 'Product';
  const capacity = cell(row, COL.capacity);
  const type     = cell(row, COL.type);
  const rawPrice = cell(row, COL.price);
  const imgUrl   = getBestImage(row);
  const price    = formatPrice(rawPrice);

  const waMsg = encodeURIComponent(
    `Hello TECIL Solar, I'd like to enquire about: ${cell(row, COL.quickName) || name}${capacity ? ' — ' + capacity : ''}. Please share availability and current pricing.`
  );

  const imgHtml = imgUrl
    ? `<img class="pcard-img" src="${imgUrl}" alt="${name}" loading="lazy"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
    : '';

  return `
  <div class="pcard"
    data-cat="${category}"
    data-brand="${brand.toLowerCase()}"
    data-search="${(name+' '+brand+' '+capacity+' '+type).toLowerCase()}"
    data-price="${rawPrice || 0}">

    <div class="pcard-img-wrap">
      ${imgHtml}
      <div class="pcard-img-ph"${imgUrl ? ' style="display:none"' : ''}>
        <svg class="ph-icon" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="2" y="2" width="20" height="20" rx="4"/><path d="M8 12h8M12 8v8"/></svg>
        <span class="ph-brand">${brand}</span>
        <span class="ph-cat">${category}</span>
      </div>
      ${type ? `<div class="pcard-type-tag">${type}</div>` : ''}
    </div>

    <div class="pcard-body">
      ${category ? `<span class="pcard-cat ${catClass(category)}">${category}</span>` : ''}
      <div class="pcard-name">${name}</div>
      ${brand ? `<div class="pcard-brand">${brand}</div>` : ''}
      ${capacity ? `
        <div class="pcard-capacity">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          ${capacity}
        </div>` : ''}
      <div class="pcard-footer">
        <div>
          ${price
            ? `<div class="pcard-price">${price}</div>
               <span class="pcard-price-label">Calabar Price</span>`
            : `<div class="pcard-price" style="font-size:.82rem;color:#9CA3AF;font-weight:600">Call for price</div>`
          }
        </div>
        <a class="pcard-enquire"
           href="https://wa.me/2348037135545?text=${waMsg}"
           target="_blank" rel="noopener">
          Enquire
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>`;
}

// ── RENDER ──
function render() {
  const grid  = document.getElementById('products-grid');
  const empty = document.getElementById('products-empty');
  const meta  = document.getElementById('products-meta');

  let filtered = allProducts.filter(row => {
    const catMatch    = activeCategory === 'all' || cell(row, COL.category) === activeCategory;
    const brandMatch  = !activeBrand || cell(row, COL.brand).toLowerCase() === activeBrand;
    const searchMatch = !searchQuery  || (row._search || '').includes(searchQuery);
    return catMatch && brandMatch && searchMatch;
  });

  // Sort
  if (sortMode === 'price-asc')  filtered.sort((a,b) => parseFloat(cell(a,COL.price)||0) - parseFloat(cell(b,COL.price)||0));
  if (sortMode === 'price-desc') filtered.sort((a,b) => parseFloat(cell(b,COL.price)||0) - parseFloat(cell(a,COL.price)||0));
  if (sortMode === 'name-asc')   filtered.sort((a,b) => cell(a,COL.modelName).localeCompare(cell(b,COL.modelName)));

  if (!filtered.length) {
    grid.style.display  = 'none';
    empty.style.display = 'flex';
    meta.style.display  = 'none';
    return;
  }

  empty.style.display = 'none';
  grid.style.display  = 'grid';
  meta.style.display  = 'block';
  meta.textContent    = `Showing ${filtered.length} of ${allProducts.length} products`;
  grid.innerHTML      = filtered.map(buildCard).join('');
}

// ── LOAD FROM SHEET ──
async function loadProducts() {
  const loading = document.getElementById('products-loading');
  const error   = document.getElementById('products-error');
  try {
    const res  = await fetch(SHEET_URL);
    if (!res.ok) throw new Error('HTTP ' + res.status);
    const text = await res.text();

    const start = text.indexOf('{');
    const end   = text.lastIndexOf('}') + 1;
    if (start < 0) throw new Error('No JSON');
    const json  = JSON.parse(text.slice(start, end));

    // Skip row 0 (title row) and row 1 (header row) — data starts at row 2
    const rows = json.table.rows.slice(2);

    allProducts = rows.filter(r =>
      r && r.c && cell(r, COL.id) && cell(r, COL.status).toLowerCase() === 'active'
    ).map(r => {
      r._search = [
        cell(r, COL.modelName),
        cell(r, COL.brand),
        cell(r, COL.capacity),
        cell(r, COL.type),
        cell(r, COL.quickName),
      ].join(' ').toLowerCase();
      return r;
    });

    // Populate brand dropdown
    const brands = [...new Set(allProducts.map(r => cell(r, COL.brand)).filter(Boolean))].sort();
    const brandSel = document.getElementById('brand-filter');
    brands.forEach(b => {
      const opt = document.createElement('option');
      opt.value = b.toLowerCase();
      opt.textContent = b;
      brandSel.appendChild(opt);
    });

    loading.style.display = 'none';
    if (!allProducts.length) throw new Error('No active products');
    document.getElementById('products-grid').style.display = 'grid';
    render();

  } catch(err) {
    console.error('Products load error:', err);
    loading.style.display = 'none';
    error.style.display   = 'flex';
  }
}

// ── EVENTS ──
document.querySelectorAll('.ftab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.ftab').forEach(t => t.classList.remove('is-active'));
    tab.classList.add('is-active');
    activeCategory = tab.dataset.cat || 'all';
    render();
    document.getElementById('product-section')?.scrollIntoView({ behavior:'smooth', block:'start' });
  });
});

let debounce;
const searchInput = document.getElementById('product-search');
const clearBtn    = document.getElementById('search-clear');
searchInput?.addEventListener('input', e => {
  clearTimeout(debounce);
  const v = e.target.value.trim().toLowerCase();
  clearBtn.style.display = v ? 'block' : 'none';
  debounce = setTimeout(() => { searchQuery = v; render(); }, 200);
});
clearBtn?.addEventListener('click', () => {
  searchInput.value = ''; clearBtn.style.display = 'none'; searchQuery = ''; render();
});

document.getElementById('brand-filter')?.addEventListener('change', e => {
  activeBrand = e.target.value; render();
});
document.getElementById('sort-filter')?.addEventListener('change', e => {
  sortMode = e.target.value; render();
});

window.resetFilters = () => {
  activeCategory = 'all'; searchQuery = ''; activeBrand = ''; sortMode = '';
  if (searchInput) searchInput.value = '';
  if (clearBtn) clearBtn.style.display = 'none';
  document.querySelectorAll('.ftab').forEach(t => t.classList.remove('is-active'));
  document.querySelector('[data-cat="all"]')?.classList.add('is-active');
  const bs = document.getElementById('brand-filter');
  const ss = document.getElementById('sort-filter');
  if (bs) bs.value = '';
  if (ss) ss.value = '';
  render();
};

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', loadProducts);
} else {
  loadProducts();
}
</script>

