</style>

<!-- ─────────────────── SCRIPT ─────────────────── -->
<script define:vars={{ SHEET_URL }}>
// ── COLUMN INDICES ──
const COL = {
  id:         0,
  category:   1,
  brand:      2,
  modelName:  3,
  capacity:   4,
  type:       5,
  quickName:  6,
  price:      7,
  heroJpeg:  10,
  pngUrl:    11,
  webpUrl:   13,
  status:    18,
};

// ── CONFIG ──
const ITEMS_PER_PAGE = 12;

// ── STATE ──
let allProducts    = [];
let currentPage    = 1;
let activeCategory = 'all';
let searchQuery    = '';
let activeBrand    = '';
let sortMode       = '';

// ── HELPERS ──
function cell(row, idx) {
  const c = row.c?.[idx];
  if (!c || c.v === null || c.v === undefined) return '';
  return String(c.v).trim();
}

function formatPrice(raw) {
  const n = parseFloat(String(raw).replace(/[^0-9.]/g, ''));
  if (!n || n === 0) return null;
  if (n >= 1_000_000) return '₦' + (n / 1_000_000).toFixed(1).replace('.0','') + 'M';
  if (n >= 1_000)     return '₦' + n.toLocaleString('en-NG');
  return '₦' + n;
}

// ── GOOGLE DRIVE IMAGE FIX ──
function extractDriveFileId(url) {
  if (!url) return null;

  const idParam = url.match(/[?&]id=([a-zA-Z0-9_-]+)/);
  if (idParam) return idParam[1];

  const filePath = url.match(/\/file\/d\/([a-zA-Z0-9_-]+)/);
  if (filePath) return filePath[1];

  return null;
}

function toGDriveThumbnail(url) {
  const id = extractDriveFileId(url);
  return id ? `https://drive.google.com/thumbnail?id=${id}&sz=w800` : url;
}

function getBestImage(row) {
  const raw = cell(row, COL.webpUrl) || cell(row, COL.heroJpeg) || cell(row, COL.pngUrl);
  return toGDriveThumbnail(raw);
}

// ── QUICK ENQUIRY ──
function quickEnquiry(name, capacity) {
  const msg = encodeURIComponent(
    `Hello TECIL Solar, I'm interested in ${name}${capacity ? ' ('+capacity+')' : ''}. Please share details.`
  );

  window.open(`https://wa.me/2348037135545?text=${msg}`, '_blank');
}

// ── PRODUCT MODAL (PREP FOR PHASE 2) ──
function openProductModal(id) {
  const product = allProducts.find(p => cell(p, COL.id) === id);
  if (!product) return;

  const name = cell(product, COL.modelName);
  const brand = cell(product, COL.brand);

  alert(`${name} (${brand})\n\nModal system coming next.`);
}

// ── CARD BUILDER (BALANCED UI) ──
function buildCard(row) {
  const id       = cell(row, COL.id);
  const brand    = cell(row, COL.brand);
  const name     = cell(row, COL.modelName) || cell(row, COL.quickName);
  const capacity = cell(row, COL.capacity);
  const type     = cell(row, COL.type);
  const rawPrice = cell(row, COL.price);
  const imgUrl   = getBestImage(row);
  const price    = formatPrice(rawPrice);

  return `
  <div class="pcard v2"
       onclick="openProductModal('${id}')">

    <div class="pcard-img-wrap">
      ${imgUrl ? `
        <img src="${imgUrl}" class="pcard-img" alt="${name}"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
      ` : ''}

      <div class="pcard-img-placeholder" ${imgUrl ? 'style="display:none"' : ''}>
        <span>${brand || 'TECIL Solar'}</span>
      </div>
    </div>

    <div class="pcard-body">

      <div class="pcard-brand">${brand}</div>
      <div class="pcard-name">${name}</div>

      <div class="pcard-meta">
        ${capacity ? `<span>${capacity}</span>` : ''}
        ${type ? `<span>${type}</span>` : ''}
      </div>

      <div class="pcard-bottom">
        <div class="pcard-price">
          ${price ? price : 'Request Price'}
        </div>

        <button class="pcard-quick"
          onclick="event.stopPropagation();quickEnquiry('${name}','${capacity}')">
          Enquire
        </button>
      </div>

    </div>
  </div>`;
}

// ── RENDER ──
function render() {
  const grid  = document.getElementById('products-grid');
  const empty = document.getElementById('products-empty');
  const meta  = document.getElementById('products-meta');

  let filtered = allProducts.filter(row => {
    const catMatch    = activeCategory === 'all' || cell(row, COL.category) === activeCategory;
    const brandMatch  = !activeBrand || cell(row, COL.brand).toLowerCase() === activeBrand;
    const searchMatch = !searchQuery  || (row._search || '').includes(searchQuery);
    return catMatch && brandMatch && searchMatch;
  });

  if (sortMode === 'price-asc')  filtered.sort((a,b) => parseFloat(cell(a,COL.price)||0) - parseFloat(cell(b,COL.price)||0));
  if (sortMode === 'price-desc') filtered.sort((a,b) => parseFloat(cell(b,COL.price)||0) - parseFloat(cell(a,COL.price)||0));
  if (sortMode === 'name-asc')   filtered.sort((a,b) => cell(a,COL.modelName).localeCompare(cell(b,COL.modelName)));

  if (!filtered.length) {
    grid.style.display  = 'none';
    empty.style.display = 'flex';
    meta.style.display  = 'none';
    return;
  }

  const start = (currentPage - 1) * ITEMS_PER_PAGE;
  const end = start + ITEMS_PER_PAGE;
  const pageItems = filtered.slice(start, end);

  empty.style.display = 'none';
  grid.style.display  = 'grid';
  meta.style.display  = 'block';
  meta.textContent    = `Showing ${start + 1}-${Math.min(end, filtered.length)} of ${filtered.length}`;

  grid.innerHTML = pageItems.map(buildCard).join('');
}

// ── LOAD DATA ──
async function loadProducts() {
  try {
    const res = await fetch(SHEET_URL);
    const text = await res.text();

    const json = JSON.parse(text.substring(text.indexOf('{'), text.lastIndexOf('}') + 1));
    const rows = json.table.rows.slice(2);

    allProducts = rows.filter(r =>
      r && r.c && cell(r, COL.id) && cell(r, COL.status).toLowerCase() === 'active'
    ).map(r => {
      r._search = [
        cell(r, COL.modelName),
        cell(r, COL.brand),
        cell(r, COL.capacity),
        cell(r, COL.type)
      ].join(' ').toLowerCase();
      return r;
    });

    document.getElementById('products-loading').style.display = 'none';

    if (!allProducts.length) {
      document.getElementById('products-empty').style.display = 'flex';
      return;
    }

    render();

  } catch (err) {
    console.error(err);
    document.getElementById('products-loading').style.display = 'none';
    document.getElementById('products-error').style.display = 'flex';
  }
}

// ── EVENTS ──
document.addEventListener('DOMContentLoaded', loadProducts);