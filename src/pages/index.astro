---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import AboutSection from '../components/AboutSection.astro';
import HomeGallerySlider from '../components/HomeGallerySlider.astro';
import BrandsStrip from '../components/BrandsStrip.astro';
import ServicesPreview from '../components/ServicesPreview.astro';
import AudienceSection from '../components/AudienceSection.astro';
import VideoSection from '../components/VideoSection.astro';
import ProjectsPreview from '../components/ProjectsPreview.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import BranchesPreview from '../components/BranchesPreview.astro';
import CTASection from '../components/CTASection.astro';
---
<Layout page="home">
  <HeroSection />
  <MarqueeStrip variant="red" />
  <AboutSection />
  <HomeGallerySlider />
  <BrandsStrip variant="light" />
  <ServicesPreview />
  <AudienceSection />
  <VideoSection />
  <MarqueeStrip variant="dark" />
  <ProjectsPreview />
  <TestimonialsSection />
  <BranchesPreview />
  <CTASection />
</Layout>