---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesPreview from '../components/ServicesPreview.astro';
import AudienceSection from '../components/AudienceSection.astro';
import ProjectsPreview from '../components/ProjectsPreview.astro';
import BranchesPreview from '../components/BranchesPreview.astro';
import CTASection from '../components/CTASection.astro';
---
<Layout page="home">
  <HeroSection />
  <MarqueeStrip variant="red" />
  <AboutSection />
  <MarqueeStrip variant="light" />
  <ServicesPreview />
  <AudienceSection />
  <MarqueeStrip variant="dark" />
  <ProjectsPreview />
  <BranchesPreview />
  <CTASection />
</Layout>
