---
import Layout from '../layouts/Layout.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import CTASection from '../components/CTASection.astro';
import { services, processSteps } from '../data/site';
---

<Layout
  title="Services — TECIL Solar"
  description="Solar installation, maintenance, assessment, supply, projects, and training from TECIL Solar."
  page="services"
>
  <section class="page-hero">
    <div class="page-hero-grid"></div>
    <div class="page-hero-orb a"></div>
    <div class="page-hero-orb b"></div>
    <div class="container">
      <span class="section-tag">What We Do</span>
      <h1>Services built for clarity and trust.</h1>
      <p class="page-hero-sub">
        The content now reads less like repetition and more like a real service catalog with a business-first layout.
      </p>
    </div>
  </section>

  <MarqueeStrip variant="red" />

  <section class="section bg-off">
    <div class="container">
      <div class="services-list">
        {services.map((item) => (
          <article class="service-detail card" id={item.id}>
            <div class="service-detail-top">
              <span>{item.eyebrow}</span>
              <strong>{item.id.toUpperCase()}</strong>
            </div>
            <h2>{item.title}</h2>
            <p>{item.summary}</p>
            <ul>
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
            <a href="/contact" class="btn-primary">Request this service</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container">
      <div class="process-head reveal">
        <div>
          <span class="section-tag">How We Work</span>
          <h2>Simple process. Better presentation.</h2>
        </div>
        <p>Four steps is enough here. It keeps the page cleaner and easier to scan.</p>
      </div>

      <div class="process-grid">
        {processSteps.map((step, index) => (
          <article class:list={['process-card', 'reveal', `reveal-delay-${index + 1}`]}>
            <span>{step.step}</span>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
  .services-list {
    display: grid;
    gap: 1rem;
  }

  .service-detail {
    padding: 1.6rem;
  }

  .service-detail-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
    color: var(--orange);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .service-detail h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    max-width: 12ch;
  }

  .service-detail p {
    margin-top: 0.85rem;
    max-width: 72ch;
  }

  .service-detail ul {
    margin: 1rem 0 1.2rem;
    padding-left: 1.15rem;
    color: var(--muted);
  }

  .service-detail li + li {
    margin-top: 0.42rem;
  }

  .process-head {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: end;
    margin-bottom: 1.4rem;
  }

  .process-head p {
    max-width: 52ch;
    font-size: 1.02rem;
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .process-card {
    padding: 1.35rem;
    border-radius: 24px;
    border: 1px solid var(--border);
    background: linear-gradient(180deg, #fff, #fafafa);
  }

  .process-card span {
    display: inline-flex;
    margin-bottom: 0.8rem;
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
    color: rgba(204,20,23,0.16);
  }

  .process-card h3 {
    font-size: 1.4rem;
  }

  .process-card p {
    margin-top: 0.55rem;
  }

  @media (max-width: 980px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .process-head {
      flex-direction: column;
      align-items: start;
    }

    .process-grid {
      grid-template-columns: 1fr;
    }
  }
</style>