---
import Layout from '../layouts/Layout.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import CTASection from '../components/CTASection.astro';
import { projects } from '../data/site';
---

<Layout
  title="Projects — TECIL Solar"
  description="TECIL Solar project work across residential, commercial, and institutional deployments."
  page="projects"
>
  <section class="page-hero">
    <div class="page-hero-grid"></div>
    <div class="page-hero-orb a"></div>
    <div class="page-hero-orb b"></div>
    <div class="container">
      <span class="section-tag">Projects</span>
      <h1>Proof that the brand can deliver.</h1>
      <p class="page-hero-sub">
        Project pages help the site feel credible by showing that the company does real work for real clients.
      </p>
    </div>
  </section>

  <MarqueeStrip variant="red" />

  <section class="section bg-dark">
    <div class="container project-grid">
      {projects.map((item, index) => (
        <article class:list={['project-card', 'reveal', `reveal-delay-${index + 1}`]}>
          <span class="project-tag">{item.tag}</span>
          <h2>{item.title}</h2>
          <p class="project-location">{item.location}</p>
          <p>{item.summary}</p>
          <div class="project-result">{item.result}</div>
        </article>
      ))}
    </div>
  </section>

  <section class="section bg-white">
    <div class="container project-strip reveal">
      <div>
        <span class="section-tag">What The Page Now Does</span>
        <h2>More emphasis on results. Less repetition.</h2>
      </div>
      <p>
        A project page should show outcomes, not just a list of services copied again.
      </p>
    </div>
  </section>

  <CTASection />
</Layout>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .project-card {
    padding: 1.45rem;
    border-radius: 28px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(12px);
    box-shadow: 0 22px 52px rgba(0,0,0,0.18);
  }

  .project-card h2 {
    color: #fff;
    font-size: 1.95rem;
    margin-top: 0.8rem;
  }

  .project-tag {
    display: inline-flex;
    padding: 0.5rem 0.72rem;
    border-radius: 999px;
    background: rgba(232,96,26,0.12);
    color: #FFBE8A;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .project-location {
    margin-top: 0.55rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.48);
  }

  .project-card p:last-of-type {
    margin-top: 0.75rem;
    color: rgba(255,255,255,0.70);
  }

  .project-result {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    color: #FFBE8A;
    font-weight: 600;
  }

  .project-strip {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    align-items: end;
  }

  .project-strip h2 {
    max-width: 10ch;
  }

  .project-strip p {
    max-width: 50ch;
    font-size: 1.02rem;
  }

  @media (max-width: 980px) {
    .project-grid {
      grid-template-columns: 1fr;
    }

    .project-strip {
      flex-direction: column;
      align-items: start;
    }
  }
</style>