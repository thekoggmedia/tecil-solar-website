---
import Layout from '../layouts/Layout.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import CTASection from '../components/CTASection.astro';

const branches = [
  { name: "Calabar HQ", state: "Cross River State", address: "Macson Plaza, 89 Ndidem Usang Iso Road, Calabar", tel: "0803 713 5545", tel2: "0803 560 1371", hq: true },
  { name: "Calabar South", state: "Cross River State", address: "6 Target Road, Calabar South", tel: "0907 124 2120" },
  { name: "Ikom", state: "Cross River State", address: "16 Obudu Road, Four Corners, Ikom", tel: "0803 560 1371" },
  { name: "Port Harcourt 1", state: "Rivers State", address: "Riz Plaza, Plot 54 Stadium Road, Port Harcourt", tel: "0701 616 4397" },
  { name: "Port Harcourt 2", state: "Rivers State", address: "18 Ogbunabali Road, Port Harcourt", tel: "0701 616 4397" },
  { name: "Uyo", state: "Akwa Ibom State", address: "109 Oron Road, Uyo", tel: "0812 113 8060" },
  { name: "Lagos / Ikeja", state: "Lagos State", address: "90 Obafemi Awolowo Way, Ikeja, Lagos", tel: "0802 683 5985" },
];
---

<Layout title="Branch Locations — TECIL Solar" description="7 TECIL Solar branches across 5 Nigerian states: Calabar, Port Harcourt, Uyo, Ikom, and Lagos." page="branches">

  <section class="page-hero">
    <div class="ph-bg"></div>
    <div class="ph-orb"></div>
    <div class="container">
      <span class="section-tag">Find Us</span>
      <h1>7 Branches. <span class="text-red-gradient">5 States.</span></h1>
      <p class="ph-sub">From Calabar to Lagos — walk into any TECIL Solar branch and get the same level of expertise, service, and product quality.</p>
    </div>
  </section>

  <MarqueeStrip variant="red" />

  <section class="branches-full dark-2-section section">
    <div class="container">

      <div class="state-group">
        {["Cross River State","Rivers State","Akwa Ibom State","Lagos State"].map(state => (
          <div class="state-block">
            <div class="state-heading">
              <span class="state-dot"></span>
              {state}
            </div>
            <div class="state-branches">
              {branches.filter(b => b.state === state).map((b, i) => (
                <div class={`branch-full-card reveal reveal-delay-${i}`}>
                  {b.hq && <span class="hq-badge">Headquarters</span>}
                  <h3 class="bf-name">{b.name}</h3>
                  <div class="bf-address">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {b.address}
                  </div>
                  <div class="bf-contacts">
                    <a href={`tel:+234${b.tel.replace(/\s/g,'').slice(1)}`} class="bf-tel">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.38a2 2 0 0 1 1.99-1.8h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17z"/></svg>
                      {b.tel}
                    </a>
                    {b.tel2 && (
                      <a href={`tel:+234${b.tel2.replace(/\s/g,'').slice(1)}`} class="bf-tel">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.61 4.38a2 2 0 0 1 1.99-1.8h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17z"/></svg>
                        {b.tel2}
                      </a>
                    )}
                    <a href={`https://wa.me/234${b.tel.replace(/\s/g,'').slice(1)}`} target="_blank" class="bf-wa">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                      WhatsApp
                    </a>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <CTASection />

</Layout>

<style>
  .page-hero { min-height: 40vh; background: #111; display: flex; align-items: center; padding: 120px 5% 80px; position: relative; overflow: hidden; }
  .ph-bg { position: absolute; inset: 0; background-image: linear-gradient(rgba(204,20,23,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(204,20,23,0.04) 1px, transparent 1px); background-size: 64px 64px; }
  .ph-orb { position: absolute; border-radius: 50%; filter: blur(80px); width: 500px; height: 500px; background: radial-gradient(circle, rgba(204,20,23,0.1) 0%, transparent 70%); top: -100px; right: -50px; }
  .page-hero .container { position: relative; z-index: 1; }
  .page-hero h1 { color: #fff; margin: 8px 0 16px; }
  .ph-sub { font-size: 1.05rem; color: rgba(255,255,255,0.5); max-width: 560px; line-height: 1.75; }

  .branches-full { background: #1A1A1A; }
  .state-group { display: flex; flex-direction: column; gap: 4rem; }
  .state-block {}
  .state-heading {
    display: flex; align-items: center; gap: 12px;
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem; font-weight: 700;
    color: #E8601A; letter-spacing: 0.14em; text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .state-dot { width: 8px; height: 8px; background: #E8601A; border-radius: 50%; }
  .state-branches { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; }

  .branch-full-card {
    background: rgba(255,255,255,0.025);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 2rem 1.75rem; position: relative;
    transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .branch-full-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, #CC1417, #E8601A); transform: scaleX(0); transform-origin: left; transition: transform 0.3s ease; }
  .branch-full-card:hover { background: rgba(232,96,26,0.05); border-color: rgba(232,96,26,0.2); transform: translateY(-3px); }
  .branch-full-card:hover::before { transform: scaleX(1); }

  .hq-badge { display: inline-block; background: #CC1417; color: #fff; font-family: 'Inter', sans-serif; font-size: 0.58rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 8px; border-radius: 2px; margin-bottom: 10px; }
  .bf-name { font-family: 'Barlow Condensed', sans-serif; font-size: 1.3rem; font-weight: 800; text-transform: uppercase; color: #fff; margin-bottom: 12px; }
  .bf-address { display: flex; align-items: flex-start; gap: 8px; font-size: 0.82rem; color: rgba(255,255,255,0.45); line-height: 1.5; margin-bottom: 14px; }
  .bf-address svg { flex-shrink: 0; margin-top: 2px; color: #E8601A; }
  .bf-contacts { display: flex; flex-wrap: wrap; gap: 8px; }
  .bf-tel, .bf-wa {
    display: inline-flex; align-items: center; gap: 5px;
    font-family: 'Inter', sans-serif; font-size: 0.78rem; font-weight: 600;
    text-decoration: none; padding: 5px 10px; border-radius: 2px;
    transition: all 0.2s;
  }
  .bf-tel { color: #E8601A; background: rgba(232,96,26,0.08); border: 1px solid rgba(232,96,26,0.15); }
  .bf-tel:hover { background: rgba(232,96,26,0.15); color: #E8601A; }
  .bf-wa { color: #25D366; background: rgba(37,211,102,0.06); border: 1px solid rgba(37,211,102,0.15); }
  .bf-wa:hover { background: #25D366; color: #fff; }

  @media (max-width: 900px) { .state-branches { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 600px) { .state-branches { grid-template-columns: 1fr; } }
</style>
