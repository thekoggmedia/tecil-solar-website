---
import Layout from '../layouts/Layout.astro';
import MarqueeStrip from '../components/MarqueeStrip.astro';
import { contactChannels } from '../data/site';
---

<Layout
  title="Contact — TECIL Solar"
  description="Contact TECIL Solar for a quote, support, or product enquiry."
  page="contact"
>
  <section class="page-hero">
    <div class="page-hero-grid"></div>
    <div class="page-hero-orb a"></div>
    <div class="page-hero-orb b"></div>
    <div class="container">
      <span class="section-tag">Contact</span>
      <h1>Get a quote without the clutter.</h1>
      <p class="page-hero-sub">
        A cleaner contact experience helps the user act faster and helps the business look more organized.
      </p>
    </div>
  </section>

  <MarqueeStrip variant="red" />

  <section class="section bg-off">
    <div class="container contact-shell">
      <div class="contact-cards">
        {contactChannels.map((item) => (
          <a class="contact-card card reveal" href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
            <span>{item.label}</span>
            <strong>{item.value}</strong>
          </a>
        ))}

        <div class="contact-card card reveal reveal-delay-2">
          <span>What happens next</span>
          <strong>We review your needs, then respond with the right solution.</strong>
        </div>
      </div>

      <form class="contact-form card reveal reveal-delay-2" id="contact-form">
        <span class="section-tag">Request a Quote</span>
        <h2>Send a clear enquiry.</h2>

        <div class="form-grid">
          <label>
            <span>Your Name</span>
            <input name="name" type="text" placeholder="Enter your name" required />
          </label>

          <label>
            <span>Phone Number</span>
            <input name="phone" type="tel" placeholder="0803 000 0000" required />
          </label>

          <label>
            <span>Email Address</span>
            <input name="email" type="email" placeholder="name@example.com" />
          </label>

          <label>
            <span>City / Location</span>
            <input name="location" type="text" placeholder="Lagos, Port Harcourt..." required />
          </label>
        </div>

        <label class="full">
          <span>What do you need?</span>
          <textarea name="message" rows="6" placeholder="Tell us about your solar or inverter need" required></textarea>
        </label>

        <button class="btn-primary" id="submit-btn" type="submit">Send via WhatsApp</button>
        <p class="form-note" id="form-note">We will open WhatsApp with a pre-filled message so you can send it instantly.</p>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact-shell {
    display: grid;
    grid-template-columns: minmax(320px, 0.85fr) minmax(0, 1.15fr);
    gap: 1.2rem;
    align-items: start;
  }

  .contact-cards {
    display: grid;
    gap: 1rem;
  }

  .contact-card {
    padding: 1.35rem;
    border-radius: 28px;
  }

  .contact-card span {
    display: inline-flex;
    margin-bottom: 0.55rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .contact-card strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.7rem;
    line-height: 1.02;
    color: var(--text);
  }

  .contact-form {
    padding: 1.5rem;
  }

  .contact-form h2 {
    margin-top: 0.5rem;
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-top: 1.2rem;
  }

  label {
    display: block;
  }

  label span {
    display: block;
    margin-bottom: 0.45rem;
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--soft);
  }

  input,
  textarea {
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: 18px;
    border: 1px solid var(--border);
    background: #fff;
    color: var(--text);
    outline: none;
    transition: var(--ease);
  }

  input:focus,
  textarea:focus {
    border-color: rgba(204,20,23,0.35);
    box-shadow: 0 0 0 4px rgba(204,20,23,0.08);
  }

  .full {
    display: block;
    margin-top: 1rem;
  }

  .btn-primary {
    margin-top: 1rem;
  }

  .form-note {
    margin-top: 0.8rem;
    font-size: 0.92rem;
  }

  @media (max-width: 980px) {
    .contact-shell {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 720px) {
    .form-grid {
      grid-template-columns: 1fr;
    }

    .contact-card strong {
      font-size: 1.45rem;
    }
  }
</style>

<script is:inline>
  const form = document.getElementById('contact-form');
  const note = document.getElementById('form-note');
  const button = document.getElementById('submit-btn');

  form?.addEventListener('submit', (event) => {
    event.preventDefault();

    const fd = new FormData(form);
    const name = String(fd.get('name') || '').trim();
    const phone = String(fd.get('phone') || '').trim();
    const email = String(fd.get('email') || '').trim();
    const location = String(fd.get('location') || '').trim();
    const message = String(fd.get('message') || '').trim();

    const whatsappText = [
      `Hello TECIL Solar, my name is ${name}.`,
      `Phone: ${phone}`,
      email ? `Email: ${email}` : null,
      `Location: ${location}`,
      '',
      message,
    ].filter(Boolean).join('\n');

    const url = `https://wa.me/2348037135545?text=${encodeURIComponent(whatsappText)}`;

    note.textContent = 'Opening WhatsApp with your enquiry...';
    button.textContent = 'Opening...';
    window.open(url, '_blank', 'noopener,noreferrer');
  });
</script>