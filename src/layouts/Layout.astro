    <ul class="nav-links">
      <li><a href="/"         class={`nav-link ${page==='home'?'is-active':''}`}>Home</a></li>
      <li><a href="/services" class={`nav-link ${page==='services'?'is-active':''}`}>Services</a></li>
      <li><a href="/products" class={`nav-link ${page==='products'?'is-active':''}`}>Products</a></li>
      <li><a href="/projects" class={`nav-link ${page==='projects'?'is-active':''}`}>Projects</a></li>
