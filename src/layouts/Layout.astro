<style>
/* NAV */
#navbar {
  position: fixed; top:0; left:0; right:0; z-index:1000;
  transition: all .35s cubic-bezier(.4,0,.2,1);
}
#navbar.on-dark {
  background: rgba(15,17,23,0.80);
  backdrop-filter: blur(14px);
  border-bottom: 1px solid rgba(255,255,255,0.07);
}
#navbar.on-dark .nl { color: rgba(255,255,255,0.80); }
#navbar.on-dark .nl:hover, #navbar.on-dark .nl.active { color: #E8601A; background: rgba(232,96,26,0.08); }
#navbar.on-dark .hbg span { background: #fff; }

#navbar.on-light {
  background: #ffffff;
  border-bottom: 1px solid #E5E7EB;
  box-shadow: 0 2px 16px rgba(0,0,0,0.07);
}
#navbar.on-light .nl { color: #374151; }
#navbar.on-light .nl:hover, #navbar.on-light .nl.active { color: #CC1417; background: rgba(204,20,23,0.05); }
#navbar.on-light .logo-mark .lt { color: #CC1417; }
#navbar.on-light .logo-mark .lo { color: #E8601A; }
#navbar.on-light .hbg span { background: #1a1a1a; }

.nav-inner {
  max-width: 1240px; margin: 0 auto; padding: 0 5%;
  height: 68px; display:flex; align-items:center; justify-content:space-between;
}
.nav-logo { display:flex; align-items:center; gap:10px; text-decoration:none; }
.logo-mark { font-family:'Big Shoulders Display',sans-serif; font-weight:900; font-size:1.6rem; letter-spacing:.04em; text-transform:uppercase; line-height:1; }
.lt { color: #CC1417; }
.lo { color: #E8601A; }
.logo-pill { background:#CC1417; color:#fff; font-family:'DM Sans',sans-serif; font-size:.57rem; font-weight:700; letter-spacing:.06em; padding:3px 9px; border-radius:20px; white-space:nowrap; }

.nav-links { display:flex; align-items:center; gap:.1rem; list-style:none; }
.nl {
  font-family:'DM Sans',sans-serif; font-size:.85rem; font-weight:500;
  text-decoration:none; padding:.45rem .85rem; border-radius:4px;
  transition:all .25s ease; letter-spacing:.02em;
}
.nl-cta {
  background:#CC1417 !important; color:#fff !important;
  padding:.5rem 1.2rem !important; font-weight:700 !important;
  margin-left:.5rem; text-transform:uppercase; font-size:.76rem !important;
  border-radius:4px; letter-spacing:.06em;
}
.nl-cta:hover { background:#A30F11 !important; color:#fff !important; transform:translateY(-1px); box-shadow:0 4px 16px rgba(204,20,23,.3) !important; }

.hbg { display:none; flex-direction:column; gap:5px; background:none; border:none; cursor:pointer; padding:4px; }
.hbg span { display:block; width:24px; height:2px; border-radius:2px; transition:all .3s ease; }
.hbg.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
.hbg.open span:nth-child(2){opacity:0}
.hbg.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}

.mob-menu {
  display:none; flex-direction:column; gap:0;
  background:#fff; border-top:3px solid #CC1417;
  padding:.75rem 5% 1.5rem;
  box-shadow: 0 8px 24px rgba(0,0,0,.1);
}
.mob-menu.open { display:flex; }
.ml { font-family:'DM Sans',sans-serif; font-size:1rem; font-weight:500; color:#222; text-decoration:none; padding:.8rem .5rem; border-bottom:1px solid #F0F0F0; transition:color .2s; }
.ml:hover { color:#CC1417; }
.ml-cta { color:#CC1417 !important; font-weight:700 !important; border-bottom:none !important; margin-top:.5rem; }

/* FOOTER */
footer { background:#0F1117; padding:5rem 0 0; border-top:3px solid #CC1417; }
.ft-grid { display:grid; grid-template-columns:2fr 1fr 1fr 1.4fr; gap:3rem; margin-bottom:3.5rem; }
.ft-logo { font-family:'Big Shoulders Display',sans-serif; font-weight:900; font-size:1.9rem; text-transform:uppercase; letter-spacing:.04em; line-height:1; margin-bottom:8px; }
.fl-r { color:#CC1417; }
.fl-o { color:#E8601A; }
.ft-pill { display:inline-block; background:#CC1417; color:#fff; font-size:.58rem; font-weight:700; letter-spacing:.08em; padding:3px 10px; border-radius:20px; margin-bottom:14px; }
.ft-brand p { font-size:.86rem; color:rgba(255,255,255,.42); line-height:1.75; margin-bottom:8px; }
.ft-parent { font-size:.65rem !important; font-weight:600 !important; color:rgba(255,255,255,.18) !important; letter-spacing:.05em; text-transform:uppercase; margin-bottom:18px !important; }
.socials { display:flex; gap:8px; flex-wrap:wrap; }
.soc { width:34px; height:34px; display:flex; align-items:center; justify-content:center; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.10); border-radius:4px; color:rgba(255,255,255,.5); text-decoration:none; transition:all .25s ease; }
.soc:hover { background:#CC1417; border-color:#CC1417; color:#fff; transform:translateY(-3px); }
.soc-wa:hover { background:#25D366 !important; border-color:#25D366 !important; }

.ft-col { display:flex; flex-direction:column; gap:0; }
.ft-col h5 { font-family:'DM Sans',sans-serif; font-size:.68rem; font-weight:700; color:#fff; letter-spacing:.14em; text-transform:uppercase; margin-bottom:1rem; }
.ft-col a { font-size:.85rem; color:rgba(255,255,255,.40); text-decoration:none; transition:color .2s; padding:.3rem 0; }
.ft-col a:hover { color:#E8601A; }
.ft-quote { margin-top:1.2rem; padding:.9rem 1.1rem; border-left:3px solid #CC1417; background:rgba(204,20,23,.06); font-size:.8rem; color:rgba(255,255,255,.38); font-style:italic; line-height:1.7; }
.ft-bottom { border-top:1px solid rgba(255,255,255,.07); padding:1.5rem 0; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:.5rem; }
.ft-bottom p { font-size:.78rem; color:rgba(255,255,255,.25); }
.ft-bottom a { color:#E8601A; }

/* WA FLOAT */
.wa-float { position:fixed; bottom:26px; right:26px; width:52px; height:52px; background:#25D366; border-radius:50%; display:flex; align-items:center; justify-content:center; color:#fff; text-decoration:none; box-shadow:0 4px 20px rgba(37,211,102,.4); z-index:999; transition:all .3s ease; }
.wa-float:hover { background:#1ebe5d; color:#fff; transform:translateY(-3px) scale(1.06); box-shadow:0 8px 30px rgba(37,211,102,.5); }

@media(max-width:768px){
  .nav-links{display:none}
  .hbg{display:flex}
  .logo-pill{display:none}
  .ft-grid{grid-template-columns:1fr;gap:2rem}
  .ft-bottom{flex-direction:column;text-align:center}
  .wa-float{bottom:18px;right:14px;width:48px;height:48px}
}
</style>
<script>
const nav = document.getElementById('navbar');
function updateNav(){
  if(!nav) return;
  if(window.scrollY > window.innerHeight * .55){
    nav.className = 'on-light';
  } else {
    nav.className = 'on-dark';
  }
}
window.addEventListener('scroll', updateNav, {passive:true});
updateNav();

const hbg = document.getElementById('hbg');
const mm = document.getElementById('mob-menu');
hbg?.addEventListener('click',()=>{ hbg.classList.toggle('open'); mm?.classList.toggle('open'); });
document.querySelectorAll('.ml').forEach(l=>l.addEventListener('click',()=>{ hbg?.classList.remove('open'); mm?.classList.remove('open'); }));

function initReveal(){
  const els = document.querySelectorAll('.reveal');
  if(!els.length) return;
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target);} });
  },{threshold:.08,rootMargin:'0px 0px -40px 0px'});
  els.forEach(el=>{ const r=el.getBoundingClientRect(); if(r.top<window.innerHeight-40){el.classList.add('visible');}else{io.observe(el);} });
}
document.addEventListener('DOMContentLoaded',initReveal);
</script>
