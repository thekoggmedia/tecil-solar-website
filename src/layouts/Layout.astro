<style>
/* ════════════════════════════════════════
   CORRECTION 1 — Brand text bigger + bolder
   ════════════════════════════════════════ */
.nav-brand {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  flex-shrink: 0;
}

.nav-brand-text {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* TECILSOLAR text — matched to logo height */
.nav-brand-text strong {
  font-family: var(--font);
  font-size: 2rem;           /* ← was 1.5rem, now matches 44px logo */
  text-transform: uppercase;
  letter-spacing: 0.04em;
  font-variation-settings: 'wdth' 125, 'wght' 950;
  line-height: 1;
  display: block;
}

/* "...the inverter place" tagline — unchanged */
.nav-tagline {
  font-size: 0.58rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  font-variation-settings: 'wdth' 100, 'wght' 600;
  margin-top: 3px;
  display: block;
  white-space: nowrap;
}
.site-nav.is-light .nav-tagline { color: var(--soft); }

/* ════════════════════════════════════════
   CORRECTION 2 — Nav collapse earlier so
   links never distort or wrap
   ════════════════════════════════════════ */

/* Desktop nav — keep all links on one line */
.nav-links {
  display: flex;
  align-items: center;
  gap: 0.15rem;
  list-style: none;
  flex-wrap: nowrap;      /* ← never wrap */
}

.nav-links li {
  flex-shrink: 0;         /* ← never squish */
}

.nav-link {
  white-space: nowrap;    /* ← text never breaks */
  padding: 0.45rem 0.7rem;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  font-variation-settings: 'wdth' 100, 'wght' 700;
}

/* Hamburger — hidden on desktop, shown below 1180px */
.nav-toggle { display: none; }

/* ── COLLAPSE BREAKPOINT ── 
   Collapse to hamburger at 1180px (was probably 768px before)
   This prevents any wrapping on medium screens              */
@media (max-width: 1180px) {
  .nav-links  { display: none; }
  .nav-toggle { display: flex; }
}

/* At very small screens make brand text slightly smaller */
@media (max-width: 480px) {
  .nav-brand-text strong { font-size: 1.6rem; }
}
</style>

<script>
const nav = document.getElementById('site-nav');
function updateNav(){
  if(!nav) return;
  if(window.scrollY > window.innerHeight * 0.5){
    nav.classList.replace('is-dark','is-light');
  } else {
    nav.classList.replace('is-light','is-dark');
  }
}
window.addEventListener('scroll', updateNav, {passive:true});
updateNav();

const toggle = document.getElementById('nav-toggle');
const mm = document.getElementById('mobile-menu');
toggle?.addEventListener('click',()=>{
  toggle.classList.toggle('is-open');
  mm?.classList.toggle('is-open');
});
document.querySelectorAll('.mobile-link').forEach(l=>l.addEventListener('click',()=>{
  toggle?.classList.remove('is-open');
  mm?.classList.remove('is-open');
}));

function initReveal(){
  const els = document.querySelectorAll('.reveal');
  if(!els.length) return;
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target); } });
  },{threshold:0.08,rootMargin:'0px 0px -40px 0px'});
  els.forEach(el=>{
    const r = el.getBoundingClientRect();
    if(r.top < window.innerHeight - 40) el.classList.add('visible');
    else io.observe(el);
  });
}
document.addEventListener('DOMContentLoaded', initReveal);
</script>