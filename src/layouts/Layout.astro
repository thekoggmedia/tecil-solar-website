---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  page?: string;
}

const {
  title = 'TECIL Solar — The Inverter Place',
  description = 'Nigeria\'s most trusted solar and inverter specialists. End-to-end renewable energy solutions for homes, businesses, and institutions since 2008. 7 branches across 5 states.',
  page = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#CC1417" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{title}</title>
  </head>

  <body>

    <!-- ── NAVBAR ── -->
    <nav id="navbar">
      <div class="nav-container">
        <a href="/" class="nav-logo">
          <div class="logo-wordmark">
            <span class="logo-tecil">TECIL</span><span class="logo-solar">Solar</span>
          </div>
          <div class="logo-tagline-pill">...the inverter place</div>
        </a>

        <ul class="nav-links">
          <li><a href="/" class={`nav-link ${page === 'home' ? 'active' : ''}`}>Home</a></li>
          <li><a href="/services" class={`nav-link ${page === 'services' ? 'active' : ''}`}>Services</a></li>
          <li><a href="/products" class={`nav-link ${page === 'products' ? 'active' : ''}`}>Products</a></li>
          <li><a href="/projects" class={`nav-link ${page === 'projects' ? 'active' : ''}`}>Projects</a></li>
          <li><a href="/branches" class={`nav-link ${page === 'branches' ? 'active' : ''}`}>Find Us</a></li>
          <li><a href="/contact" class="nav-link nav-cta">Get a Quote</a></li>
        </ul>

        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
          <span></span>
          <span></span>
          <span></span>
        </button>
      </div>

      <div class="mobile-menu" id="mobile-menu">
        <ul class="mobile-links">
          <li><a href="/" class="mobile-link">Home</a></li>
          <li><a href="/services" class="mobile-link">Services</a></li>
          <li><a href="/products" class="mobile-link">Products</a></li>
          <li><a href="/projects" class="mobile-link">Projects</a></li>
          <li><a href="/branches" class="mobile-link">Find Us</a></li>
          <li><a href="/contact" class="mobile-link mobile-link-cta">Get a Quote</a></li>
        </ul>
      </div>
    </nav>

    <!-- ── PAGE CONTENT ── -->
    <main>
      <slot />
    </main>

    <!-- ── FOOTER ── -->
    <footer class="footer">
      <div class="container">
        <div class="footer-top">

          <!-- Brand Column -->
          <div class="footer-brand">
            <div class="footer-wordmark">
              <span class="fw-red">TECIL</span><span class="fw-orange">Solar</span>
            </div>
            <div class="footer-tag-pill">...the inverter place</div>
            <p class="footer-desc">
              Nigeria's most trusted solar and inverter specialists.
              End-to-end renewable energy solutions for homes, businesses,
              and institutions since 2008.
            </p>
            <p class="footer-parent">A division of TECIL INTEGRATED SERVICES LIMITED</p>
            <div class="social-links">
              <a href="https://instagram.com/tecilsolar" target="_blank" rel="noopener" class="social-link" aria-label="Instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
              </a>
              <a href="https://facebook.com/tecilsolar" target="_blank" rel="noopener" class="social-link" aria-label="Facebook">
