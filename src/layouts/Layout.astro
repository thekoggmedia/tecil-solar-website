---
import '../styles/global.css';
interface Props { title?: string; description?: string; page?: string; }
const {
  title = 'TECIL Solar — The Inverter Place',
  description = "Nigeria's leading solar and inverter specialists. End-to-end renewable energy solutions for homes, businesses, and institutions. Operating across Lagos, Port Harcourt, Calabar, Uyo and beyond.",
  page = '',
