<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content={description}/>
  <meta name="theme-color" content="#CC1417"/>
  <meta property="og:title" content={title}/>
  <meta property="og:description" content={description}/>
  <meta property="og:type" content="website"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <title>{title}</title>
</head>
<body>

<nav id="navbar">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <div class="logo-mark"><span class="lt">TECIL</span><span class="lo">Solar</span></div>
      <span class="logo-pill">...the inverter place</span>
    </a>
    <ul class="nav-links">
      <li><a href="/" class={`nl ${page==='home'?'active':''}`}>Home</a></li>
      <li><a href="/services" class={`nl ${page==='services'?'active':''}`}>Services</a></li>
      <li><a href="/products" class={`nl ${page==='products'?'active':''}`}>Products</a></li>
      <li><a href="/projects" class={`nl ${page==='projects'?'active':''}`}>Projects</a></li>
      <li><a href="/branches" class={`nl ${page==='branches'?'active':''}`}>Find Us</a></li>
      <li><a href="/contact" class="nl nl-cta">Get a Quote</a></li>
    </ul>
    <button class="hbg" id="hbg" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="mob-menu" id="mob-menu">
    <a href="/" class="ml">Home</a>
    <a href="/services" class="ml">Services</a>
    <a href="/products" class="ml">Products</a>
    <a href="/projects" class="ml">Projects</a>
    <a href="/branches" class="ml">Find Us</a>
    <a href="/contact" class="ml ml-cta">Get a Quote →</a>
  </div>
</nav>

